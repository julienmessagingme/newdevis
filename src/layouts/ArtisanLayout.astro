---
// Layout minimal pour l'Espace Artisan (portail externe, sans compte).
// Volontairement nu : pas de nav marketing, pas de popup newsletter, pas de tracking
// (un artisan invité n'est pas une cible marketing) → noindex + juste l'essentiel.
import '@/index.css';

interface Props {
  title?: string;
}
const { title = 'Espace Artisan — GérerMonChantier' } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content="Espace artisan — déposez vos documents, consultez le planning du chantier." />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="preload" href="/_astro/dm-sans-latin-400-normal.CW0RaeGs.woff2" as="font" type="font/woff2" crossorigin />
  </head>
  <body>
    <slot />
  </body>
</html>
