---
import Logo from './Logo.astro';

// CTA "Tester gratuitement". Defaut = /beta (accroche). Une page peut surcharger :
// notamment /beta elle-meme pointe vers le tunnel (sinon recliquer = page courante = rien).
interface Props { ctaHref?: string }
const { ctaHref = '/beta' } = Astro.props;

const featureMenu = [
  { h: "Vue d'ensemble", links: [
    { href: '/logiciel-suivi-chantier', t: 'Logiciel de suivi chantier' },
    { href: '/application-suivi-travaux', t: 'Application de suivi travaux' },
    { href: '/application-gestion-chantier', t: 'Application de gestion chantier' },
  ] },
  { h: 'Modules clés', links: [
    { href: '/planning-chantier', t: 'Planning chantier' },
    { href: '/suivi-budget-travaux', t: 'Suivi budget travaux' },
    { href: '/gestion-artisans-travaux', t: 'Gestion artisans' },
    { href: '/gestion-documents-chantier', t: 'Documents chantier' },
  ] },
  { h: 'Problèmes fréquents', links: [
    { href: '/retard-chantier', t: 'Retard chantier' },
    { href: '/surcout-travaux', t: 'Surcoût travaux' },
    { href: '/budget-renovation', t: 'Budget rénovation' },
    { href: '/coordination-artisans', t: 'Coordination artisans' },
  ] },
];
---

<header class="sticky top-0 z-40 backdrop-blur-md bg-white/85 border-b border-gray-100">
  <div class="max-w-[1240px] mx-auto px-4 sm:px-6 h-16 flex items-center gap-3 sm:gap-8">
    <a href="/" class="cursor-pointer shrink-0" aria-label="Gérer Mon Chantier — accueil">
      <span class="sm:hidden"><Logo size="sm" /></span>
      <span class="hidden sm:inline-flex"><Logo size="md" /></span>
    </a>
    <nav class="hidden md:flex items-center gap-7 text-sm font-medium text-gray-600">
      <div class="relative group" id="gmc-feat-dd">
        <a href="/#fonctionnalites" id="gmc-feat-trigger" aria-haspopup="true" aria-expanded="false" class="inline-flex items-center gap-1 cursor-pointer hover:text-gray-900">
          Fonctionnalités
          <svg class="w-3.5 h-3.5 text-gray-400 transition-transform group-hover:rotate-180 group-[.is-open]:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
          </svg>
        </a>
        <div class="absolute left-1/2 -translate-x-1/2 top-full pt-3 hidden group-hover:block group-[.is-open]:block z-50">
          <div class="w-[680px] bg-white rounded-2xl border border-gray-100 shadow-xl p-5 grid grid-cols-3 gap-x-6 gap-y-1">
            {featureMenu.map((col) => (
              <div>
                <p class="text-[10px] font-bold uppercase tracking-[.14em] text-[#F58A06] mb-2">{col.h}</p>
                <ul class="space-y-0.5">
                  {col.links.map((l) => (
                    <li>
                      <a href={l.href} class="block px-2 py-1.5 rounded-lg text-[13px] text-gray-700 hover:bg-[#F5F7FB] hover:text-[#1B3FA1] transition-colors">{l.t}</a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </div>
      <a href="/#tarifs" class="cursor-pointer hover:text-gray-900">Tarifs</a>
    </nav>
    <div class="flex-1"></div>

    {/* Connexion (visiteur non logué) — caché par JS si user logué */}
    <a
      id="gmc-login-btn"
      href="/connexion"
      class="hidden md:inline-flex shrink-0 items-center text-sm font-semibold cursor-pointer text-gray-700 hover:text-gray-900"
    >
      Connexion
    </a>

    {/* User dropdown (utilisateur logué) — révélé par JS si auth-token en localStorage */}
    <div id="gmc-user-dropdown" class="relative hidden">
      <button
        id="gmc-user-trigger"
        type="button"
        class="flex items-center gap-1.5 text-sm font-medium text-gray-700 hover:text-gray-900 transition-colors px-3 py-1.5"
      >
        <span id="gmc-user-name" class="truncate max-w-[120px]"></span>
        <svg class="h-3.5 w-3.5 transition-transform" id="gmc-user-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
        </svg>
      </button>
      <div id="gmc-user-menu" class="absolute top-full right-0 mt-1 w-48 rounded-lg border border-gray-100 bg-white shadow-lg py-1 z-50 hidden">
        <a id="gmc-user-chantier-link" href="/mon-chantier" class="hidden px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 transition-colors">
          🏗️ Mes chantiers
        </a>
        <button id="gmc-signout-btn" type="button" class="block w-full text-left px-4 py-2 text-sm text-red-600 hover:bg-red-50 transition-colors">
          Déconnexion
        </button>
      </div>
    </div>

    {/* CTA principal — toujours visible */}
    <a
      href={ctaHref}
      class="inline-flex shrink-0 items-center gap-1.5 text-sm font-semibold px-3 sm:px-4 h-10 rounded-xl shadow-sm cursor-pointer transition-colors bg-[#F58A06] hover:bg-[#E47C00] text-white whitespace-nowrap"
    >
      <span class="sm:hidden">Tester</span>
      <span class="hidden sm:inline">Tester gratuitement</span>
      <svg class="hidden sm:block" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="M5 12h14M13 5l7 7-7 7" />
      </svg>
    </a>

    <button
      id="gmc-mobile-menu-btn"
      type="button"
      class="md:hidden inline-flex shrink-0 items-center justify-center w-10 h-10 -mr-1 rounded-lg text-gray-700 hover:bg-gray-100 cursor-pointer"
      aria-label="Ouvrir le menu"
      aria-expanded="false"
      aria-controls="gmc-mobile-menu"
    >
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <path d="M4 7h16M4 12h16M4 17h16" />
      </svg>
    </button>
  </div>

  <div id="gmc-mobile-menu" class="md:hidden hidden border-t border-gray-100 bg-white/95 backdrop-blur-md max-h-[80vh] overflow-y-auto">
    <nav class="max-w-[1240px] mx-auto px-4 py-2 flex flex-col text-[15px] font-medium text-gray-700">
      <a href="/#fonctionnalites" class="py-2.5 cursor-pointer hover:text-[#1B3FA1]">Fonctionnalités</a>
      {featureMenu.map((col) => (
        <div class="pl-3 border-l border-gray-100 ml-1 mb-1">
          <p class="text-[10px] font-bold uppercase tracking-[.14em] text-[#F58A06] mt-2 mb-1">{col.h}</p>
          {col.links.map((l) => (
            <a href={l.href} class="block py-1.5 text-[13px] font-normal text-gray-600 hover:text-[#1B3FA1]">{l.t}</a>
          ))}
        </div>
      ))}
      <a href="/#tarifs" class="py-2.5 cursor-pointer hover:text-[#1B3FA1] border-t border-gray-100 mt-1 pt-3">Tarifs</a>
      <a id="gmc-mobile-login" href="/connexion" class="py-2.5 cursor-pointer hover:text-[#1B3FA1]">Connexion</a>
    </nav>
  </div>
</header>

<script>
  // ── Dropdown Fonctionnalités : clic = ouverture (tactile + accessibilité) ──
  const featTrigger = document.getElementById('gmc-feat-trigger');
  const featDd = document.getElementById('gmc-feat-dd');
  featTrigger?.addEventListener('click', (e) => {
    e.preventDefault();
    const open = featDd?.classList.toggle('is-open') === true;
    featTrigger.setAttribute('aria-expanded', String(open));
  });
  document.addEventListener('click', (e) => {
    if (featDd && !featDd.contains(e.target as Node)) {
      featDd.classList.remove('is-open');
      featTrigger?.setAttribute('aria-expanded', 'false');
    }
  });

  // ── Détection user connecté + bascule UI Connexion / Espace ─────────────
  // Lit localStorage Supabase (clé `sb-*-auth-token`) au load. Si user trouvé,
  // remplace le bouton "Connexion" par le menu user (Mes chantiers + Déconnexion).
  // Le lien "Mes chantiers" n'apparaît que pour les users allowlistés
  // (hasGmcAccess) — pour les autres, juste Déconnexion.
  try {
    const keys = Object.keys(localStorage).filter(k => k.includes('auth-token'));
    let user: { email?: string; user_metadata?: { first_name?: string; last_name?: string } } | null = null;
    for (const key of keys) {
      const data = JSON.parse(localStorage.getItem(key) || '{}');
      if (data?.user) { user = data.user; break; }
    }
    if (user) {
      // Hide login button, show user dropdown
      document.getElementById('gmc-login-btn')?.classList.add('hidden');
      document.getElementById('gmc-mobile-login')?.classList.add('hidden');
      const dropdown = document.getElementById('gmc-user-dropdown');
      dropdown?.classList.remove('hidden');

      // User name
      const firstName = user.user_metadata?.first_name || '';
      const lastName = user.user_metadata?.last_name || '';
      const displayName = [firstName, lastName].filter(Boolean).join(' ')
        || (user.email ? user.email.split('@')[0] : '');
      const nameEl = document.getElementById('gmc-user-name');
      if (nameEl) nameEl.textContent = `Espace ${displayName}`;

      // "Mes chantiers" visible pour tout utilisateur connecté — l'accès réel est
      // contrôlé côté serveur (abonnement / essai). L'ancienne allowlist en dur
      // masquait le lien aux vrais abonnés, qui ne pouvaient donc pas rejoindre
      // leur tableau de bord depuis le header.
      document.getElementById('gmc-user-chantier-link')?.classList.remove('hidden');
    }
  } catch {
    // Mode privé strict ou similaire — non bloquant, on garde le bouton Connexion
  }

  // ── Dropdown hover/click ────────────────────────────────────────────────
  const trigger = document.getElementById('gmc-user-trigger');
  const menu = document.getElementById('gmc-user-menu');
  const chevron = document.getElementById('gmc-user-chevron');
  const dropdown = document.getElementById('gmc-user-dropdown');
  let hideTimer: ReturnType<typeof setTimeout>;

  dropdown?.addEventListener('mouseenter', () => {
    clearTimeout(hideTimer);
    menu?.classList.remove('hidden');
    chevron?.style.setProperty('transform', 'rotate(180deg)');
  });
  dropdown?.addEventListener('mouseleave', () => {
    hideTimer = setTimeout(() => {
      menu?.classList.add('hidden');
      chevron?.style.setProperty('transform', '');
    }, 150);
  });
  // Click ouvre/ferme aussi (mobile et accessibilité)
  trigger?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  // ── Sign out (helper partagé qui gère le cross-domain) ──────────────────
  document.getElementById('gmc-signout-btn')?.addEventListener('click', async () => {
    const { signOutCrossDomain } = await import('@/lib/auth/signOut');
    await signOutCrossDomain('/');
  });

  // ── Menu mobile ──────────────────────────────────────────────────────────
  const mobileBtn = document.getElementById('gmc-mobile-menu-btn');
  const mobileMenu = document.getElementById('gmc-mobile-menu');
  mobileBtn?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.toggle('hidden') === false;
    mobileBtn.setAttribute('aria-expanded', String(isOpen));
  });
  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('hidden');
      mobileBtn?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
