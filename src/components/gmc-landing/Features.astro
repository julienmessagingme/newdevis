---
const items = [
  { ic: '📐', t: 'Planning CPM', b: 'Drag-and-drop, dépendances multi-parents, recalcul auto à chaque imprévu.' },
  { ic: '💬', t: 'Messagerie unifiée', b: 'Vrais groupes WhatsApp + email reply-to dédié par chantier. Accusés de lecture.' },
  { ic: '📥', t: 'Devis vérifiés', b: 'Pipeline VerifierMonDevis intégré : score fiabilité, SIRET, comparaison marché.' },
  { ic: '💸', t: 'Budget & Trésorerie', b: 'Aides, prêts, acomptes, soldes. Échéancier prédictif sur 14 semaines.' },
  { ic: '📁', t: 'Documents', b: 'Devis, factures, photos, plans, frais — classés et liés au bon lot, automatiquement.' },
  { ic: '📓', t: 'Journal IA quotidien', b: 'Chaque soir, un résumé écrit du jour : décisions, alertes, ce qui a bougé.' },
  { ic: '🔔', t: 'Rappels intelligents', b: 'Le Pilote programme les relances et vous prévient même app fermée.' },
  { ic: '🏘️', t: 'Multi-chantiers', b: 'Plusieurs projets, un seul compte. Vue agrégée et bascule en un clic.' },
];
---

<section id="fonctionnalites" class="py-14 scroll-mt-20">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="max-w-2xl mb-14">
      <h2 class="font-bold text-[#0E1730] text-4xl sm:text-5xl leading-[1.05] tracking-tight">
        Tout ce qu'il vous faut, dans un seul cockpit.
      </h2>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {items.map((it) => (
        <div class="bg-white border border-gray-100 rounded-2xl p-5 hover:border-[#1B3FA1]/30 hover:shadow-lg hover:-translate-y-0.5 transition-all">
          <div class="w-10 h-10 rounded-xl bg-[#EFF4FF] flex items-center justify-center text-xl mb-3">{it.ic}</div>
          <h3 class="font-bold text-[#0E1730] text-sm">{it.t}</h3>
          <p class="mt-2 text-xs text-gray-600 leading-relaxed">{it.b}</p>
        </div>
      ))}
    </div>
  </div>
</section>
