---
interface Props {
  size?: 'sm' | 'md' | 'lg' | 'xl';
  dark?: boolean;
  animated?: boolean;
}

const { size = 'md', dark = false, animated = true } = Astro.props;

const sizes = {
  sm: { mark: 28, font: 14, gap: 8 },
  md: { mark: 36, font: 18, gap: 10 },
  lg: { mark: 48, font: 24, gap: 12 },
  xl: { mark: 72, font: 36, gap: 16 },
};
const s = sizes[size];
const ink = dark ? '#fff' : '#1A2233';
const mutedColor = dark ? 'rgba(255,255,255,.55)' : '#677084';
---

<div class="inline-flex items-center" style={`gap:${s.gap}px`}>
  <svg width={s.mark} height={s.mark} viewBox="0 0 48 48" fill="none">
    <rect x="2" y="2" width="44" height="44" rx="11" fill="#1B3FA1" />
    <rect x="2" y="2" width="44" height="44" rx="11" fill="url(#gmc-shine)" opacity="0.18" />

    <g opacity="0.18" stroke="#fff" stroke-width="0.5">
      <path d="M8 14h32M8 22h32M8 30h32M8 38h32M14 8v32M22 8v32M30 8v32M38 8v32" />
    </g>

    <path
      d="M11 30 L24 18 L37 30 L37 39 L11 39 Z"
      stroke="#fff"
      stroke-width="2.2"
      stroke-linejoin="round"
      stroke-linecap="round"
      fill="none"
      class={animated ? 'gmc-house' : ''}
    />
    <rect
      x="21"
      y="32"
      width="6"
      height="7"
      stroke="#fff"
      stroke-width="1.6"
      fill="none"
      class={animated ? 'gmc-door' : ''}
    />

    <g class={animated ? 'gmc-crane-arm' : ''}>
      <line
        x1="14" y1="12" x2="32" y2="12"
        stroke="#F58A06" stroke-width="2" stroke-linecap="round"
        class={animated ? 'gmc-line-h' : ''}
      />
      <line
        x1="14" y1="12" x2="14" y2="30"
        stroke="#F58A06" stroke-width="2" stroke-linecap="round"
        class={animated ? 'gmc-line-v' : ''}
      />
      <line x1="29" y1="12" x2="29" y2="20" stroke="#fff" stroke-width="1" stroke-dasharray="2 2" />
      <rect x="27" y="20" width="4" height="3" fill="#F58A06" class={animated ? 'gmc-load' : ''} />
    </g>

    <defs>
      <linearGradient id="gmc-shine" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0" stop-color="#fff" />
        <stop offset="1" stop-color="#fff" stop-opacity="0" />
      </linearGradient>
    </defs>
  </svg>
  <div class="leading-none flex flex-col" style="gap:2px">
    <span class="font-bold tracking-tight" style={`font-size:${s.font}px;color:${ink}`}>
      Gérer<span style="color:#F58A06">Mon</span>Chantier
    </span>
    <span
      class="uppercase font-bold tracking-[0.18em]"
      style={`font-size:${Math.max(8, s.font * 0.45)}px;color:${mutedColor}`}
    >
      Pilote IA de chantier
    </span>
  </div>
</div>

<style>
  @keyframes gmc-draw { to { stroke-dashoffset: 0; } }
  @keyframes gmc-crane { 0%,100% { transform: rotate(0deg); } 50% { transform: rotate(6deg); } }
  @keyframes gmc-bob { 0%,100% { transform: translateY(0); } 50% { transform: translateY(2px); } }

  .gmc-house {
    stroke-dasharray: 110;
    stroke-dashoffset: 110;
    animation: gmc-draw 1.6s 0.1s ease-out forwards;
  }
  .gmc-door {
    stroke-dasharray: 30;
    stroke-dashoffset: 30;
    animation: gmc-draw 0.6s 1.1s ease-out forwards;
  }
  .gmc-line-h {
    stroke-dasharray: 20;
    stroke-dashoffset: 20;
    animation: gmc-draw 0.5s 0.8s ease-out forwards;
  }
  .gmc-line-v {
    stroke-dasharray: 20;
    stroke-dashoffset: 20;
    animation: gmc-draw 0.5s 0.5s ease-out forwards;
  }
  .gmc-crane-arm {
    transform-origin: 14px 12px;
    animation: gmc-crane 4s 1.7s ease-in-out infinite;
  }
  .gmc-load {
    animation: gmc-bob 4s 1.7s ease-in-out infinite;
  }
</style>
