---
import Logo from './Logo.astro';

const cols = [
  { h: 'Produit', l: [
    { label: 'Fonctionnalités', href: '/#fonctionnalites' },
    { label: 'Pilote IA', href: '/#pilote' },
    { label: 'Tarifs', href: '/#tarifs' },
    { label: 'Sécurité', href: '/securite' },
  ]},
  { h: 'Ressources', l: [
    { label: 'Guide rénovation', href: '/guide-renovation' },
    { label: 'Aides énergétiques', href: '/aides-energetiques' },
    { label: 'Blog', href: '/blog' },
    { label: 'VerifierMonDevis', href: 'https://www.verifiermondevis.fr' },
  ]},
  { h: 'Société', l: [
    { label: 'À propos', href: '/qui-sommes-nous' },
    { label: 'Contact', href: '/contact' },
    { label: 'CGU', href: '/cgu' },
    { label: 'Confidentialité', href: '/confidentialite' },
  ]},
];
---

<footer class="bg-[#0E1730] text-white/70 py-14">
  <div class="max-w-[1200px] mx-auto px-6 grid md:grid-cols-[2fr_1fr_1fr_1fr] gap-10">
    <div>
      <Logo size="md" dark animated={false} />
      <p class="mt-4 text-sm leading-relaxed max-w-sm">
        Le copilote des chantiers. Conçu en France, hébergé chez OVH.
      </p>
      <div class="mt-4 flex items-center gap-3">
        <a
          href="https://www.instagram.com/verifiermondevis/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Instagram VerifierMonDevis"
          class="text-white/70 hover:text-white transition-colors"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
            <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
          </svg>
        </a>
        <a
          href="https://www.facebook.com/profile.php?id=61567601962826"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Facebook VerifierMonDevis"
          class="text-white/70 hover:text-white transition-colors"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
          </svg>
        </a>
        <a
          href="https://www.tiktok.com/@gerermonchantier"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="TikTok GérerMonChantier"
          class="text-white/70 hover:text-white transition-colors"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5.8 20.1a6.34 6.34 0 0 0 10.86-4.43V8.66a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1.84-.09z"/>
          </svg>
        </a>
      </div>
      <p class="mt-4 text-xs flex items-center gap-2">
        <span class="bg-white/10 px-2 py-1 rounded-md">Sœur de</span>
        <a class="font-semibold text-white hover:text-[#F58A06] cursor-pointer" href="https://www.verifiermondevis.fr">VerifierMonDevis.fr →</a>
      </p>
    </div>
    {cols.map((c) => (
      <div>
        <p class="text-[11px] font-bold uppercase tracking-[.15em] text-white mb-3">{c.h}</p>
        <ul class="space-y-2 text-xs">
          {c.l.map((i) => (
            <li><a class="hover:text-white cursor-pointer" href={i.href}>{i.label}</a></li>
          ))}
        </ul>
      </div>
    ))}
  </div>
  <div class="max-w-[1200px] mx-auto px-6 mt-10 pt-6 border-t border-white/10 flex flex-wrap justify-between items-center gap-4 text-[11px]">
    <p>© 2026 GérerMonChantier · Tous droits réservés</p>
    <p>RGPD · Données hébergées en France</p>
  </div>
</footer>
