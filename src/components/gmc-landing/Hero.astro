---
import HouseIllustration from './HouseIllustration.astro';
import Logo from './Logo.astro';
---

<section class="relative overflow-hidden bg-white">
  <div class="absolute inset-0 -z-10 pointer-events-none">
    <div class="absolute inset-0 bg-gradient-to-b from-[#F5F6FA] via-white to-white"></div>
    <div class="absolute -top-32 -right-32 w-[520px] h-[520px] rounded-full bg-[#1B3FA1] opacity-[0.06] blur-3xl"></div>
    <div class="absolute -bottom-32 -left-20 w-[440px] h-[440px] rounded-full bg-[#F58A06] opacity-[0.05] blur-3xl"></div>
    <svg class="absolute inset-0 w-full h-full opacity-[0.035]" aria-hidden="true">
      <defs>
        <pattern id="gridA" width="40" height="40" patternUnits="userSpaceOnUse">
          <path d="M 40 0 L 0 0 0 40" fill="none" stroke="#1B3FA1" stroke-width="0.5" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#gridA)" />
    </svg>
  </div>

  <div class="max-w-[1240px] mx-auto px-6 pt-14 pb-14 grid lg:grid-cols-[1fr_1.05fr] gap-10 lg:gap-14 items-center">
    <div>
      <h1
        class="mt-5 font-bold text-[#0E1730] text-[40px] sm:text-[54px] leading-[1.05] tracking-tight hi-fade"
        style="animation-delay:.1s"
      >
        Votre chantier,{' '}
        <span class="relative inline-block">
          <span class="relative z-10">piloté</span>
          <svg class="absolute left-0 -bottom-1 w-full" viewBox="0 0 220 14" fill="none" preserveAspectRatio="none">
            <path
              d="M3 11 C 60 4, 160 4, 217 10"
              stroke="#F58A06" stroke-width="4" stroke-linecap="round"
              class="hi-underline"
            />
          </svg>
        </span>{' '}au millimètre.
      </h1>

      <p class="mt-5 text-lg text-gray-600 max-w-[520px] leading-relaxed hi-fade" style="animation-delay:.25s">
        Planifier les lots, répondre aux artisans sur WhatsApp, classer les
        devis, suivre la trésorerie, déclencher les rappels…&nbsp;
        <strong class="text-gray-900">GMC orchestre tout.</strong>
        &nbsp;Vous arbitrez. Le Pilote exécute.
      </p>

      <div class="mt-7 hi-fade" style="animation-delay:.35s">
        <p class="text-[11px] font-bold uppercase tracking-[.16em] text-gray-500 mb-3">Vous en êtes où&nbsp;?</p>
        <div class="grid sm:grid-cols-2 gap-3">
          <a
            href="#etapes-start"
            class="group relative bg-white border border-gray-200 hover:border-[#1B3FA1] hover:shadow-lg transition-all rounded-2xl p-4 cursor-pointer overflow-hidden"
          >
            <span class="absolute -top-6 -right-6 w-20 h-20 rounded-full bg-[#1B3FA1] opacity-0 group-hover:opacity-10 blur-2xl transition-opacity"></span>
            <div class="flex items-center gap-2.5 mb-2">
              <span class="w-9 h-9 rounded-xl bg-[#EFF4FF] flex items-center justify-center text-lg">🌱</span>
              <span class="text-[10px] font-bold tracking-wider text-[#1B3FA1] uppercase">Page blanche</span>
            </div>
            <p class="font-semibold text-[#0E1730] text-[15px] leading-snug">Je démarre un projet.</p>
            <p class="mt-1.5 text-xs text-gray-600 leading-relaxed">Décrivez votre projet. Le Pilote pose 4 questions, structure les lots et propose un budget cible.</p>
            <span class="mt-3 inline-flex items-center gap-1 text-xs font-semibold text-[#1B3FA1] group-hover:gap-2 transition-all">
              Démarrer le projet
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M5 12h14M13 5l7 7-7 7" />
              </svg>
            </span>
          </a>

          <a
            href="#etapes-resume"
            class="group relative bg-white border border-gray-200 hover:border-[#F58A06] hover:shadow-lg transition-all rounded-2xl p-4 cursor-pointer overflow-hidden"
          >
            <span class="absolute -top-6 -right-6 w-20 h-20 rounded-full bg-[#F58A06] opacity-0 group-hover:opacity-15 blur-2xl transition-opacity"></span>
            <div class="flex items-center gap-2.5 mb-2">
              <span class="w-9 h-9 rounded-xl bg-[#FFF1DD] flex items-center justify-center text-lg">📂</span>
              <span class="text-[10px] font-bold tracking-wider text-[#F58A06] uppercase">Devis en main</span>
            </div>
            <p class="font-semibold text-[#0E1730] text-[15px] leading-snug">J'ai déjà mes devis.</p>
            <p class="mt-1.5 text-xs text-gray-600 leading-relaxed">Déposez-les. Le Pilote extrait lots, montants, dates · monte le planning · ouvre la tréso. Opérationnel en 10 min.</p>
            <span class="mt-3 inline-flex items-center gap-1 text-xs font-semibold text-[#F58A06] group-hover:gap-2 transition-all">
              Importer mes devis
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M5 12h14M13 5l7 7-7 7" />
              </svg>
            </span>
          </a>
        </div>
        <p class="mt-3 text-[13px] text-gray-600 leading-relaxed"><span class="font-semibold text-gray-800">1 mois d'essai libre</span> · sans CB · vous quittez quand vous voulez.</p>
      </div>

      <div class="mt-6 hi-fade" style="animation-delay:.5s">
        <button
          type="button"
          id="demo-open-btn"
          aria-label="Voir la démo en 60 secondes"
          class="group relative block w-full max-w-[400px] aspect-video rounded-2xl overflow-hidden cursor-pointer shadow-lg ring-1 ring-black/5 bg-gradient-to-br from-[#1B3FA1] to-[#0E1730]"
        >
          <svg class="absolute inset-0 w-full h-full opacity-[0.1]" aria-hidden="true">
            <defs>
              <pattern id="demoGrid" width="32" height="32" patternUnits="userSpaceOnUse">
                <path d="M 32 0 L 0 0 0 32" fill="none" stroke="#fff" stroke-width="0.5" />
              </pattern>
            </defs>
            <rect width="100%" height="100%" fill="url(#demoGrid)" />
          </svg>
          <span class="absolute -top-12 -right-12 w-44 h-44 rounded-full bg-[#F58A06] opacity-25 blur-3xl"></span>

          <div class="absolute top-4 left-4">
            <Logo size="sm" dark={true} />
          </div>

          <span class="absolute inset-0 flex items-center justify-center">
            <span class="w-14 h-14 rounded-full bg-white/95 shadow-xl flex items-center justify-center transition-transform group-hover:scale-110">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="#1B3FA1" class="ml-0.5">
                <polygon points="6 4 20 12 6 20 6 4" />
              </svg>
            </span>
          </span>

          <span class="absolute bottom-4 left-4 right-4 flex items-center justify-between">
            <span class="text-white font-semibold text-sm">Voir la démo</span>
            <span class="text-white/70 text-xs font-bold uppercase tracking-[.16em]">60 s</span>
          </span>
        </button>
      </div>
    </div>

    <div class="relative">
      <HouseIllustration />
    </div>
  </div>
</section>

<div
  id="demo-modal"
  class="fixed inset-0 z-[60] hidden opacity-0 transition-opacity duration-200"
  role="dialog"
  aria-modal="true"
  aria-label="Démo Gérer Mon Chantier"
>
  <div id="demo-backdrop" class="absolute inset-0 bg-black/30 backdrop-blur-md cursor-pointer"></div>

  <div class="absolute inset-0 flex items-center justify-center p-4 sm:p-8 pointer-events-none">
    <div class="relative w-full max-w-[1280px] aspect-video bg-black rounded-2xl shadow-2xl overflow-hidden pointer-events-auto">
      <iframe
        id="demo-iframe"
        title="Démo Gérer Mon Chantier"
        class="w-full h-full border-0 block"
        allow="autoplay"
        loading="lazy"
      ></iframe>
      <button
        type="button"
        id="demo-close-btn"
        aria-label="Fermer la démo"
        class="absolute top-3 right-3 w-10 h-10 rounded-full bg-white/95 hover:bg-white shadow-lg flex items-center justify-center text-gray-700 transition-colors"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <path d="M18 6L6 18M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>
</div>

<script is:inline>
  (() => {
    const openBtn = document.getElementById('demo-open-btn');
    const modal = document.getElementById('demo-modal');
    const backdrop = document.getElementById('demo-backdrop');
    const closeBtn = document.getElementById('demo-close-btn');
    const iframe = document.getElementById('demo-iframe');
    if (!openBtn || !modal || !iframe) return;

    const open = () => {
      iframe.src = '/demo/?embed=1';
      modal.classList.remove('hidden');
      // Force reflow so the opacity transition fires.
      void modal.offsetWidth;
      modal.classList.remove('opacity-0');
      document.body.style.overflow = 'hidden';
    };
    const close = () => {
      modal.classList.add('opacity-0');
      document.body.style.overflow = '';
      // Wait for the fade-out, then unmount the iframe (stops playback + frees memory).
      setTimeout(() => {
        modal.classList.add('hidden');
        iframe.src = 'about:blank';
      }, 200);
    };

    openBtn.addEventListener('click', open);
    closeBtn?.addEventListener('click', close);
    backdrop?.addEventListener('click', close);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) close();
    });
  })();
</script>

<style>
  .hi-fade {
    opacity: 0;
    transform: translateY(8px);
    animation: hi-fade .8s ease-out forwards;
  }
  @keyframes hi-fade { to { opacity: 1; transform: none; } }
  .hi-underline {
    stroke-dasharray: 230;
    stroke-dashoffset: 230;
    animation: hi-draw 1.1s 1.1s ease-out forwards;
  }
  @keyframes hi-draw { to { stroke-dashoffset: 0; } }
</style>
