---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ResetPasswordApp from '@/components/app/ResetPasswordApp';
import { detectBrandFromHost, getConfigForBrand } from '@/lib/brand';

export const prerender = false;

const brand = detectBrandFromHost(Astro.request.headers.get('host'));
const config = getConfigForBrand(brand);
---

<BaseLayout
  title={`Nouveau mot de passe | ${config.name}`}
  description={`Choisissez un nouveau mot de passe pour votre compte ${config.name}.`}
  siteName={config.name}
  noindex={true}
>
  <ResetPasswordApp client:only="react" brand={brand} />
</BaseLayout>
