---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HubPageApp from '@/components/app/HubPageApp';
import { breadcrumbSchema } from '@/lib/seo/schemaOrg';

const url = 'https://www.verifiermondevis.fr/guides';
const title = "Tous les guides VerifierMonDevis";
const description = "Comprendre, comparer, négocier, signer ou refuser un devis travaux. Tous nos guides experts mis à jour en 2026.";

const breadcrumbs = breadcrumbSchema([
  { name: "Accueil", url: "https://www.verifiermondevis.fr/" },
  { name: "Guides", url },
]);

const props = {
  breadcrumb: [{ name: "Guides", href: "/guides" }],
  title,
  intro: description,
  subPages: [
    { href: "/guides/devis-travaux", title: "Le guide complet du devis travaux", excerpt: "Comprendre, comparer, négocier, signer ou refuser. Le pilier de référence.", topics: ["devis"], type: "pillar" },
    { href: "/observatoire", title: "L'Observatoire des devis travaux", excerpt: "Statistiques réelles : prix par métier, erreurs fréquentes, postes surfacturés.", topics: ["verifier", "prix"], type: "study" },
    { href: "/verifier-devis-travaux", title: "Vérifier un devis avec notre IA", excerpt: "Analyse gratuite en 30 secondes contre 891 prix marché.", topics: ["devis", "verifier"], type: "tool" },
    { href: "/comparateur", title: "Comparer plusieurs devis", excerpt: "Analysez plusieurs devis pour un même chantier avec un verdict expert.", topics: ["comparateur", "devis"], type: "tool" },
  ],
  showGmcGateway: true,
  footerHtml: `
    <h2>D'autres guides thématiques en préparation</h2>
    <p>Nous préparons des guides dédiés sur les sous-sujets clés : comprendre un devis ligne à ligne, la méthode pour comparer plusieurs devis, les leviers de négociation, refuser un devis sans frais, signer en sécurité, choisir un artisan, lire un verdict VMD, et les aides énergétiques.</p>
    <p>En attendant, le <a href="/guides/devis-travaux">guide pilier du devis travaux</a> couvre l'essentiel de ces sujets, et <a href="/observatoire">l'Observatoire</a> publie les statistiques réelles issues des analyses.</p>
  `,
};

export const prerender = false;
---

<BaseLayout title={title + " | VerifierMonDevis.fr"} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbs)} />
  <HubPageApp {...props} client:only="react" />
</BaseLayout>
