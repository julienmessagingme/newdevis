---
export const prerender = false;
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/astro/Header.astro";
import Footer from "../components/astro/Footer.astro";
import PassSereniteApp from "../components/app/PassSereniteApp";
---

<BaseLayout
  title="Pass Sérénité — Analyses illimitées | VerifierMonDevis.fr"
  description="Passez au Pass Sérénité pour analyser tous vos devis en illimité, télécharger vos rapports PDF et trier par type de travaux. 4,99€/mois, sans engagement."
  canonical="https://www.verifiermondevis.fr/pass-serenite"
  breadcrumbs={[
    { name: "Accueil", url: "https://www.verifiermondevis.fr/" },
    { name: "Pass Sérénité", url: "https://www.verifiermondevis.fr/pass-serenite" }
  ]}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Pass Sérénité",
    "description": "Analysez tous vos devis de travaux en illimité. Rapports PDF, comparaison prix marché, vérification entreprise.",
    "brand": { "@type": "Organization", "name": "VerifierMonDevis.fr" },
    "offers": {
      "@type": "Offer",
      "price": "4.99",
      "priceCurrency": "EUR",
      "availability": "https://schema.org/InStock",
      "priceValidUntil": "2027-12-31",
      "url": "https://www.verifiermondevis.fr/pass-serenite"
    }
  }}
>
  <Header />
  <main>
    <!-- Contenu statique SEO visible par Google -->
    <section class="ps-seo">
      <div class="ps-seo-inner">
        <h1>Pass Sérénité — Analysez vos devis en illimité</h1>
        <p class="ps-subtitle">Protégez-vous sur tous vos projets de travaux avec des analyses de devis illimitées, des rapports PDF téléchargeables et la comparaison des prix du marché.</p>

        <div class="ps-features">
          <div class="ps-feature">
            <span class="ps-icon">♾️</span>
            <h2>Analyses illimitées</h2>
            <p>Analysez autant de devis que vous le souhaitez, sans aucune restriction. La version gratuite est limitée à 5 analyses.</p>
          </div>
          <div class="ps-feature">
            <span class="ps-icon">📄</span>
            <h2>Rapport PDF</h2>
            <p>Téléchargez un rapport complet pour chaque analyse, partageable avec votre entourage ou votre banque.</p>
          </div>
          <div class="ps-feature">
            <span class="ps-icon">📊</span>
            <h2>Tri par type de travaux</h2>
            <p>Classez et comparez vos devis par catégorie : plomberie, électricité, toiture, peinture...</p>
          </div>
          <div class="ps-feature">
            <span class="ps-icon">🛡️</span>
            <h2>Tranquillité d'esprit</h2>
            <p>Faites analyser chaque devis reçu sans compter. Protégez-vous sur tous vos projets de travaux.</p>
          </div>
        </div>

        <div class="ps-pricing">
          <p><strong>4,99 €/mois</strong> — Sans engagement, résiliable à tout moment.</p>
        </div>

        <h2>Comparaison gratuit vs Pass Sérénité</h2>
        <table class="ps-table">
          <thead>
            <tr><th>Fonctionnalité</th><th>Gratuit</th><th>Pass Sérénité</th></tr>
          </thead>
          <tbody>
            <tr><td>Analyses de devis</td><td>5 à vie</td><td>Illimitées ✅</td></tr>
            <tr><td>Score de fiabilité</td><td>✅</td><td>✅</td></tr>
            <tr><td>Vérification entreprise</td><td>✅</td><td>✅</td></tr>
            <tr><td>Comparaison prix marché</td><td>✅</td><td>✅</td></tr>
            <tr><td>Tri par type de travaux</td><td>❌</td><td>✅</td></tr>
            <tr><td>Rapport PDF téléchargeable</td><td>❌</td><td>✅</td></tr>
            <tr><td>Prix</td><td>Gratuit</td><td>4,99 €/mois</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Composant React interactif (Stripe checkout, auth) -->
    <PassSereniteApp client:only="react" />
  </main>
  <Footer />
</BaseLayout>

<style>
  .ps-seo {
    max-width: 900px;
    margin: 0 auto;
    padding: 48px 24px 32px;
  }
  .ps-seo-inner h1 {
    font-size: clamp(24px, 4vw, 36px);
    font-weight: 800;
    color: #0B1F3A;
    text-align: center;
    margin-bottom: 16px;
  }
  .ps-subtitle {
    text-align: center;
    color: #64748b;
    font-size: 16px;
    line-height: 1.7;
    max-width: 640px;
    margin: 0 auto 40px;
  }
  .ps-features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
    margin-bottom: 32px;
  }
  .ps-feature {
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    padding: 24px 20px;
    text-align: center;
  }
  .ps-icon {
    font-size: 32px;
    display: block;
    margin-bottom: 12px;
  }
  .ps-feature h2 {
    font-size: 16px;
    font-weight: 700;
    color: #0B1F3A;
    margin-bottom: 8px;
  }
  .ps-feature p {
    font-size: 13px;
    color: #64748b;
    line-height: 1.6;
  }
  .ps-pricing {
    text-align: center;
    font-size: 18px;
    color: #0B1F3A;
    margin-bottom: 36px;
    padding: 16px;
    background: #eff6ff;
    border-radius: 12px;
  }
  .ps-seo-inner > h2 {
    font-size: 20px;
    font-weight: 700;
    color: #0B1F3A;
    margin-bottom: 16px;
  }
  .ps-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
    margin-bottom: 24px;
  }
  .ps-table th,
  .ps-table td {
    padding: 12px 16px;
    text-align: left;
    border-bottom: 1px solid #e2e8f0;
  }
  .ps-table th {
    background: #f1f5f9;
    font-weight: 600;
    color: #0B1F3A;
  }
  .ps-table td:nth-child(3) {
    color: #1a56db;
    font-weight: 600;
  }
</style>
