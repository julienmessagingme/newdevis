---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AstroHeader from '@/components/astro/Header.astro';
import AstroFooter from '@/components/astro/Footer.astro';

// ── Données tableaux de prix ─────────────────────────────────────────────────

const prixPiscines = [
  {
    type: "Piscine coque polyester",
    taille: "7×3,5 m (standard)",
    min: "15 000 €",
    moy: "22 000 €",
    max: "35 000 €",
    badge: "green",
    avantages: ["Installation rapide (1 à 2 semaines)", "Entretien facile", "Paroi lisse anti-algues"],
    inconvenients: ["Dimensions limitées aux moules", "Moins personnalisable"],
  },
  {
    type: "Piscine béton / maçonnerie",
    taille: "8×4 m (classique)",
    min: "30 000 €",
    moy: "45 000 €",
    max: "80 000 €",
    badge: "blue",
    avantages: ["Sur-mesure total", "Durabilité maximale", "Formes libres"],
    inconvenients: ["Délai de construction long (4 à 8 semaines)", "Entretien plus exigeant"],
  },
  {
    type: "Piscine en kit / acier",
    taille: "6×3 m (entrée de gamme)",
    min: "5 000 €",
    moy: "12 000 €",
    max: "20 000 €",
    badge: "amber",
    avantages: ["Budget accessible", "Montage rapide"],
    inconvenients: ["Durabilité moindre", "Moins esthétique"],
  },
];

const postes = [
  { poste: "Terrassement + évacuation terres", ht: "3 200 €", notes: "Variable selon nature du sol (+50 % si rocheux)" },
  { poste: "Coque polyester 8×4 m fournie posée", ht: "14 500 €", notes: "Inclut livraison et mise en place" },
  { poste: "Équipements filtration (pompe, filtre, skimmer)", ht: "2 800 €", notes: "Pompe basse consommation recommandée" },
  { poste: "Raccordements électriques", ht: "1 200 €", notes: "Tableautin dédié, norme NF C 15-100" },
  { poste: "Plage béton + dallage (40 m²)", ht: "4 600 €", notes: "Béton lavé, dallage grès cérame ou bois composite" },
  { poste: "Escalier intégré + margelles", ht: "1 800 €", notes: "Souvent non inclus dans le prix coque seul" },
  { poste: "Volet roulant immergé", ht: "3 400 €", notes: "Option souvent présentée comme accessoire" },
  { poste: "Traitements & mise en eau initiale", ht: "450 €", notes: "Analyse eau + produits démarrage" },
];

const erreurs = [
  {
    niveau: "red",
    titre: "Le prix \"piscine seule\" sans terrassement ni plage",
    texte: "L'erreur la plus répandue : un artisan annonce 14 000 € pour une piscine coque, mais ce prix n'inclut pas le terrassement (2 000 à 5 000 €), la plage béton (3 000 à 6 000 €) ni les raccordements (1 000 à 2 500 €). Le budget réel est systématiquement 30 à 50 % plus élevé que le prix affiché.",
  },
  {
    niveau: "red",
    titre: "L'absence du poste \"imprévus de terrassement\"",
    texte: "La nature du terrain ne se sait qu'au creusement. Sol argileux, nappe phréatique, présence de roches : chaque aléa entraîne un surcoût. Un devis sérieux prévoit une provision pour sujétions imprévues, généralement 5 à 10 % du poste terrassement.",
  },
  {
    niveau: "amber",
    titre: "Le volet roulant et les équipements présentés en option",
    texte: "Volet roulant, pompe à chaleur, éclairage LED, robot de nettoyage, douche de plage : présentées séparément, ces options représentent souvent 8 000 à 15 000 € supplémentaires sur un devis qui semblait raisonnable. Demandez systématiquement un devis \"tout compris\" pour comparer.",
  },
  {
    niveau: "amber",
    titre: "La sous-estimation du raccordement électrique",
    texte: "La réglementation NF C 15-100 impose des protections spécifiques autour des piscines (zone 0, 1, 2). Un tableau électrique dédié avec disjoncteurs différentiels 30 mA est obligatoire. Certains devis mentionnent simplement \"raccordement électrique\" sans préciser la conformité réglementaire.",
  },
  {
    niveau: "amber",
    titre: "L'entretien annuel non budgété",
    texte: "Produits de traitement (chlore, pH, anti-algues) : 300 à 600 €/an. Hivernage et remise en route : 200 à 400 €/an. Contrat de maintenance équipements : 150 à 300 €/an. Soit 650 à 1 300 € de coût annuel récurrent que la quasi-totalité des acheteurs ne prend pas en compte.",
  },
];

const checklistAnalyse = [
  { ok: true,  item: "Terrassement détaillé (volume de terres, évacuation, prix au m³)" },
  { ok: true,  item: "Fourniture ET pose de la coque ou du béton (pas l'un sans l'autre)" },
  { ok: true,  item: "Raccordements électriques avec mention de la conformité NF C 15-100" },
  { ok: true,  item: "Plage, margelles et escalier inclus (ou chiffrés séparément)" },
  { ok: true,  item: "Équipements de filtration spécifiés (marque, référence, débit)" },
  { ok: true,  item: "Numéro SIRET et assurance décennale/RC pro de l'entreprise" },
  { ok: true,  item: "Délai de réalisation et planning prévisionnel" },
  { ok: false, item: "\"Piscine posée\" sans mention du terrassement" },
  { ok: false, item: "Prix global sans décomposition par poste" },
  { ok: false, item: "Équipements listés \"en option\" non chiffrés" },
  { ok: false, item: "Absence de garantie décennale sur le génie civil" },
  { ok: false, item: "Acompte demandé supérieur à 30 % avant démarrage" },
];

const faqs = [
  {
    question: "Quel est le prix d'une piscine 8×4 m en 2026 ?",
    answer: "Pour une piscine 8×4 m, comptez en moyenne : 35 000 à 50 000 € pour une coque polyester posée clé en main (terrassement + plage basique inclus) ; 50 000 à 75 000 € pour une piscine béton équipée avec plage carrelée et volet roulant ; 15 000 à 25 000 € pour un kit acier assemblé (hors terrassement et plage). Ces prix incluent la mise en eau et les équipements de filtration de base. Les options (pompe à chaleur, robot, éclairage LED) représentent 5 000 à 15 000 € supplémentaires."
  },
  {
    question: "Piscine coque ou piscine béton : laquelle choisir ?",
    answer: "La piscine coque est recommandée si vous souhaitez une installation rapide (1 à 2 semaines), un entretien simplifié et un budget maîtrisé. Elle convient à 80 % des projets standards. La piscine béton s'impose si vous souhaitez une forme sur-mesure, des dimensions atypiques (>12 m, profil de plage progressif) ou une intégration architecturale exigeante. Elle nécessite 4 à 8 semaines de travaux et un budget souvent 40 à 60 % plus élevé. Dans les deux cas, l'essentiel est de vérifier que le devis inclut le génie civil complet, pas seulement la fourniture de la coque ou du béton."
  },
  {
    question: "Quel est le budget total réel pour une piscine, tout compris ?",
    answer: "Pour une piscine coque 8×4 m classique, le budget total réaliste est : fourniture et pose 14 000–18 000 € + terrassement 3 000–6 000 € + plage + margelles 4 000–8 000 € + électricité 1 000–2 500 € + volet roulant 2 500–4 500 € + pompe à chaleur (optionnel) 3 500–7 000 € = total entre 28 000 et 46 000 €. À quoi s'ajoutent l'entretien annuel (700–1 200 €/an) et les éventuels travaux de clôture (obligation légale de sécurité, 1 500 à 4 000 € selon le type)."
  },
  {
    question: "Quelles démarches administratives pour une piscine ?",
    answer: "Piscine ≤ 10 m² de bassin ou couverture ≤ 1,80 m : aucune déclaration. Piscine de 10 à 100 m² de surface de bassin : déclaration préalable de travaux (délai d'instruction 1 mois). Piscine > 100 m² ou couverte d'une structure ≥ 1,80 m de hauteur : permis de construire. Dans tous les cas, une clôture de sécurité (norme NF P90-306) est obligatoire pour tout bassin > 1,50 m de longueur et > 0,50 m de profondeur — prévoir 1 500 à 4 000 € selon le type de dispositif choisi."
  },
  {
    question: "Un devis piscine peut-il évoluer après signature ?",
    answer: "Oui, c'est fréquent — mais cela ne doit pas être une surprise si le devis est bien rédigé. Les seules causes légitimes de dépassement sont les aléas de terrassement imprévus (nappe phréatique, roches, accès difficile) et les travaux supplémentaires explicitement demandés par le client après signature. Tout autre surcoût doit faire l'objet d'un avenant écrit signé avant exécution. Méfiez-vous des devis qui n'incluent pas de provision pour aléas : l'artisan a toujours la possibilité de facturer les imprévus, mais s'il n'en parle pas en amont, il cherche peut-être à afficher un prix d'appel bas."
  },
  {
    question: "Comment vérifier qu'une entreprise de piscine est sérieuse ?",
    answer: "Vérifiez systématiquement : (1) le numéro SIRET et l'activité déclarée (Code NAF 4333Z ou 4121A pour le génie civil) ; (2) l'assurance décennale et la responsabilité civile professionnelle — demandez l'attestation avant signature ; (3) les avis Google (note ≥ 4/5 sur au moins 15 avis récents) ; (4) l'adhésion à la FPP (Fédération des Professionnels de la Piscine) ou à Qualipiscine. VerifierMonDevis.fr vérifie automatiquement ces éléments lors de l'analyse de votre devis."
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Devis piscine : prix réel, budget et pièges à éviter (2026)",
  "description": "Combien coûte vraiment une piscine en 2026 ? Prix moyens par type, exemple de devis réel annoté, erreurs fréquentes et checklist d'analyse complète.",
  "author": { "@type": "Person", "name": "Julien Dumas" },
  "publisher": {
    "@type": "Organization",
    "name": "VerifierMonDevis.fr",
    "logo": { "@type": "ImageObject", "url": "https://www.verifiermondevis.fr/images/logo.webp" }
  },
  "datePublished": "2026-04-14",
  "dateModified": "2026-04-14",
  "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.verifiermondevis.fr/devis-piscine-prix" },
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": { "@type": "Answer", "text": faq.answer }
  }))
};

const badgeColors: Record<string, string> = {
  green: "bg-emerald-100 text-emerald-700 border-emerald-200",
  blue:  "bg-blue-100 text-blue-700 border-blue-200",
  amber: "bg-amber-100 text-amber-700 border-amber-200",
};
---

<BaseLayout
  title="Devis piscine : prix réel, budget et pièges à éviter (2026)"
  description="Combien coûte vraiment une piscine en 2026 ? Prix par type (coque, béton, kit), exemple de devis réel annoté, erreurs fréquentes et checklist pour ne rien oublier."
  canonical="https://www.verifiermondevis.fr/devis-piscine-prix"
  ogType="article"
  jsonLd={jsonLd}
  breadcrumbs={[
    { name: "Accueil", url: "https://www.verifiermondevis.fr/" },
    { name: "Devis piscine — prix 2026", url: "https://www.verifiermondevis.fr/devis-piscine-prix" }
  ]}
>
  <!-- FAQ JSON-LD dans le body — validé par Google Search Console -->
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <div class="min-h-screen flex flex-col">
    <AstroHeader />

    <main class="flex-1">

      <!-- ══════════════════════════════════════════
           HERO
      ══════════════════════════════════════════ -->
      <section class="bg-gradient-to-b from-cyan-950 to-slate-900 text-white py-16 sm:py-20">
        <div class="container max-w-4xl px-4">

          <a href="/" class="inline-flex items-center gap-2 text-slate-400 hover:text-white mb-8 transition-colors text-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
            </svg>
            Retour à l'accueil
          </a>

          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/10 text-xs font-medium text-cyan-200 mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            </svg>
            Guide prix · Mis à jour avril 2026
          </div>

          <h1 class="text-3xl sm:text-4xl font-bold leading-tight mb-5">
            Devis piscine : combien ça&nbsp;coûte<br class="hidden sm:block" />
            vraiment en&nbsp;2026&nbsp;?
          </h1>

          <p class="text-base sm:text-lg text-slate-300 leading-relaxed max-w-2xl mb-4">
            Vous avez reçu des devis piscine avec des écarts de 15 000 à 60 000 €
            pour le même projet&nbsp;? Vous n'êtes pas seul. Les prix de la piscine sont
            parmi les moins transparents du bâtiment — entre les postes cachés,
            les options non chiffrées et les prix d'appel, le budget réel finit
            presque toujours bien au-dessus du devis initial.
          </p>
          <p class="text-sm text-slate-400 mb-8">
            Ce guide vous donne les vrais chiffres du marché 2026 et les outils pour
            lire un devis piscine sans vous faire piéger.
          </p>

          <div class="flex flex-col sm:flex-row gap-3">
            <a
              href="/nouvelle-analyse"
              class="inline-flex items-center justify-center gap-2 bg-cyan-500 hover:bg-cyan-400 text-white font-semibold px-6 py-3 rounded-xl transition-colors text-sm"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" />
              </svg>
              Analyser mon devis piscine gratuitement
            </a>
            <a
              href="#prix"
              class="inline-flex items-center justify-center gap-2 border border-white/30 text-white hover:bg-white/10 font-semibold px-6 py-3 rounded-xl transition-colors text-sm"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zM3.75 12h.007v.008H3.75V12zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm-.375 5.25h.007v.008H3.75v-.008zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
              </svg>
              Voir les prix par type
            </a>
          </div>

          <!-- Stats -->
          <div class="mt-10 grid grid-cols-3 gap-4 sm:gap-6 border-t border-white/10 pt-8">
            {[
              { value: "+38 %",   label: "de dépassement budgétaire moyen constaté" },
              { value: "3 sur 5", label: "devis piscine omettent au moins un poste majeur" },
              { value: "2 min",   label: "pour détecter les anomalies de votre devis" },
            ].map(stat => (
              <div class="text-center">
                <div class="text-xl sm:text-2xl font-bold text-white mb-1">{stat.value}</div>
                <div class="text-xs text-slate-400 leading-snug">{stat.label}</div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- ══════════════════════════════════════════
           CORPS
      ══════════════════════════════════════════ -->
      <article class="py-12 sm:py-16">
        <div class="container max-w-3xl px-4">

          <!-- ── SECTION 1 : PRIX PAR TYPE ── -->
          <section class="mb-12" id="prix">
            <h2 class="text-2xl font-bold text-slate-900 mb-2">
              Prix moyen d'une piscine en 2026
            </h2>
            <p class="text-slate-500 text-sm mb-6">
              Fourchettes constatées sur des projets réels en France métropolitaine,
              hors Île-de-France (majorer de 15 à 25 % en zone parisienne).
            </p>

            <div class="space-y-5">
              {prixPiscines.map(p => (
                <div class="border border-slate-200 rounded-xl overflow-hidden">
                  <div class="flex items-center justify-between gap-4 p-5 bg-slate-50 border-b border-slate-200">
                    <div>
                      <h3 class="font-semibold text-slate-900">{p.type}</h3>
                      <p class="text-xs text-slate-500 mt-0.5">Exemple : {p.taille}</p>
                    </div>
                    <span class={`flex-shrink-0 text-xs font-semibold px-3 py-1 rounded-full border ${badgeColors[p.badge]}`}>
                      {p.moy} en moyenne
                    </span>
                  </div>
                  <div class="p-5">
                    <!-- Barre de prix -->
                    <div class="flex items-center gap-3 mb-4">
                      <span class="text-xs text-slate-500 w-16 text-right flex-shrink-0">Min</span>
                      <div class="flex-1 relative h-3 bg-slate-100 rounded-full overflow-hidden">
                        <div class="absolute left-0 top-0 h-full bg-gradient-to-r from-emerald-400 via-amber-400 to-red-400 w-full rounded-full opacity-40"></div>
                        <div class="absolute left-[30%] top-[-3px] h-5 w-0.5 bg-slate-400"></div>
                      </div>
                      <span class="text-xs text-slate-500 w-16 flex-shrink-0">Max</span>
                    </div>
                    <div class="flex justify-between text-xs font-semibold text-slate-700 mb-4 px-[4.5rem]">
                      <span>{p.min}</span>
                      <span class="text-primary">{p.moy}</span>
                      <span>{p.max}</span>
                    </div>
                    <div class="grid grid-cols-2 gap-4 text-sm">
                      <div>
                        <p class="text-xs font-semibold text-slate-500 mb-2 uppercase tracking-wide">Avantages</p>
                        <ul class="space-y-1">
                          {p.avantages.map(a => (
                            <li class="flex items-start gap-1.5 text-slate-600">
                              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-emerald-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                              </svg>
                              <span class="text-xs">{a}</span>
                            </li>
                          ))}
                        </ul>
                      </div>
                      <div>
                        <p class="text-xs font-semibold text-slate-500 mb-2 uppercase tracking-wide">Limites</p>
                        <ul class="space-y-1">
                          {p.inconvenients.map(i => (
                            <li class="flex items-start gap-1.5 text-slate-600">
                              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-amber-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m12-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
                              </svg>
                              <span class="text-xs">{i}</span>
                            </li>
                          ))}
                        </ul>
                      </div>
                    </div>
                  </div>
                </div>
              ))}
            </div>

            <div class="mt-5 p-4 bg-cyan-50 border border-cyan-200 rounded-xl text-sm text-cyan-800">
              <strong>Rappel important&nbsp;:</strong> ces prix correspondent à la piscine
              <em>clé en main</em> avec terrassement et plage basique.
              Les prix d'appel que vous voyez souvent en ligne (à partir de 9 900 €)
              correspondent à la coque ou au kit <em>seul</em>, hors pose, hors terrassement,
              hors plage, hors raccordements.
            </div>
          </section>

          <!-- ── CTA 1 ── -->
          <div class="my-10 bg-gradient-to-r from-cyan-50 to-blue-50 border border-cyan-200 rounded-2xl p-6 text-center">
            <p class="text-base font-semibold text-slate-900 mb-1">Votre devis est dans ces fourchettes&nbsp;?</p>
            <p class="text-sm text-slate-600 mb-4">Déposez-le sur VerifierMonDevis.fr. L'outil compare chaque ligne aux prix de référence et détecte les postes manquants en 2 minutes.</p>
            <a href="/nouvelle-analyse" class="inline-flex items-center justify-center gap-2 bg-cyan-600 hover:bg-cyan-500 text-white font-semibold px-6 py-3 rounded-xl transition-colors text-sm">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" />
              </svg>
              Analyser mon devis piscine — c'est gratuit
            </a>
          </div>

          <!-- ── SECTION 2 : EXEMPLE RÉEL DE DEVIS ── -->
          <section class="mb-12" id="exemple-devis">
            <h2 class="text-2xl font-bold text-slate-900 mb-2">
              Exemple réel de devis piscine annoté
            </h2>
            <p class="text-slate-500 text-sm mb-6">
              Projet&nbsp;: piscine coque 8×4 m, terrain plat, région Rhône-Alpes (2025).
              Devis anonymisé issu d'un projet client.
            </p>

            <div class="overflow-x-auto -mx-4 sm:mx-0 rounded-xl border border-slate-200">
              <table class="min-w-[560px] w-full text-sm">
                <thead>
                  <tr class="bg-slate-800 text-white">
                    <th class="text-left px-4 py-3 font-medium rounded-tl-xl">Poste</th>
                    <th class="text-right px-4 py-3 font-medium w-28">Montant HT</th>
                    <th class="text-left px-4 py-3 font-medium rounded-tr-xl">Note d'analyse</th>
                  </tr>
                </thead>
                <tbody>
                  {postes.map((row, i) => (
                    <tr class={i % 2 === 0 ? "bg-white" : "bg-slate-50"}>
                      <td class="px-4 py-3 text-slate-800 font-medium border-b border-slate-100">{row.poste}</td>
                      <td class="px-4 py-3 text-right text-slate-900 font-semibold border-b border-slate-100 tabular-nums">{row.ht}</td>
