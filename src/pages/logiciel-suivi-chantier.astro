            {[
              { href: "/application-suivi-travaux", title: "Application de suivi travaux", desc: "Centralisez tout au même endroit" },
              { href: "/application-gestion-chantier", title: "Application de gestion chantier", desc: "Gérez votre projet de A à Z" },
              { href: "/planning-chantier", title: "Planning chantier", desc: "Dates, dépendances, retards" },
              { href: "/suivi-budget-travaux", title: "Suivi budget travaux", desc: "Maîtrisez chaque euro" },
            ].map(link => (
