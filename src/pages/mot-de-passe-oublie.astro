---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ForgotPasswordApp from '@/components/app/ForgotPasswordApp';
import { detectBrandFromHost, getConfigForBrand } from '@/lib/auth/brand';

export const prerender = false;

const brand = detectBrandFromHost(Astro.request.headers.get('host'));
const config = getConfigForBrand(brand);
const canonicalBase = brand === 'gmc'
  ? 'https://www.gerermonchantier.fr'
  : 'https://www.verifiermondevis.fr';
---

<BaseLayout
  title={`Mot de passe oublié | ${config.name}`}
  description={`Réinitialisez votre mot de passe ${config.name}.`}
  canonical={`${canonicalBase}/mot-de-passe-oublie`}
  siteName={config.name}
  noindex={true}
>
  <ForgotPasswordApp client:only="react" brand={brand} />
</BaseLayout>
