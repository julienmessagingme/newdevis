---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AstroHeader from '@/components/astro/Header.astro';
import AstroFooter from '@/components/astro/Footer.astro';
import DevisCalculatorSection from '@/components/landing/DevisCalculatorSection';

export const prerender = false;
---

<BaseLayout
  title="Calculette prix des travaux | VerifierMonDevis.fr"
  description="Estimez le prix moyen de vos travaux par type de chantier. Comparez aux prix du marché avant de demander un devis."
  canonical="https://www.verifiermondevis.fr/calculette-travaux"
  breadcrumbs={[
    { name: "Accueil", url: "https://www.verifiermondevis.fr/" },
    { name: "Calculette travaux", url: "https://www.verifiermondevis.fr/calculette-travaux" }
  ]}
>
  <div class="min-h-screen flex flex-col">
    <AstroHeader />
    <main class="flex-1">
      <div class="container max-w-3xl py-10 px-4">
        <a href="/" class="inline-flex items-center gap-1.5 text-sm text-slate-400 hover:text-slate-700 mb-8 transition-colors">
          <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
          </svg>
          Retour à l'accueil
        </a>
      </div>
      <DevisCalculatorSection client:load />
    </main>
    <AstroFooter />
  </div>
</BaseLayout>
