---
import BaseLayout from '@/layouts/BaseLayout.astro';

export const prerender = false;
---

<BaseLayout
  title="Connexion en cours…"
  description="Redirection après authentification."
  noindex={true}
>
  <div class="min-h-screen flex items-center justify-center">
    <div class="text-center space-y-4">
      <div class="animate-spin h-8 w-8 border-4 border-primary border-t-transparent rounded-full mx-auto"></div>
      <p class="text-muted-foreground">Connexion en cours...</p>
    </div>
  </div>

  <script>
    import { createClient } from "@supabase/supabase-js";
    import { detectBrandFromHost } from "@/lib/auth/brand";
    import { performPostLoginRedirect } from "@/lib/auth/postLoginRedirect";
    import { trackPixel } from "@/lib/integrations/metaPixel";

    const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL || "";
    const supabaseKey = import.meta.env.PUBLIC_SUPABASE_PUBLISHABLE_KEY || "";
    const supabase = createClient(supabaseUrl, supabaseKey);

    async function handleCallback() {
      const params = new URLSearchParams(window.location.search);
      const hashParams = new URLSearchParams(window.location.hash.substring(1));

      // Extract redirect param BEFORE Supabase processes the URL (it may get lost).
      // `next` est utilisé par le SSO handoff cross-domaine (api/sso/handoff),
      // `redirect` est l'ancien param legacy (compatibilité).
      const redirect = params.get("next") || params.get("redirect")
        || hashParams.get("next") || hashParams.get("redirect") || null;
      if (redirect) {
        sessionStorage.setItem("vmd_oauth_redirect", redirect);
      }

      // 1. Handle PKCE flow: exchange code for session
      const code = params.get("code");
      if (code) {
        const { data, error } = await supabase.auth.exchangeCodeForSession(code);
        if (error || !data.session) {
          console.error("PKCE exchange failed:", error?.message);
          window.location.href = "/connexion?error=oauth";
          return;
        }
        await handleSession(data.session);
        return;
      }

      // 2. Handle implicit flow: tokens in hash fragment
      const accessToken = hashParams.get("access_token");
      if (accessToken) {
        // Supabase auto-detects hash tokens, wait for session
        await new Promise(r => setTimeout(r, 500));
      }

      // 3. Fallback: try getSession (may already be set by Supabase client)
      const { data: { session }, error } = await supabase.auth.getSession();

      if (error || !session) {
        await new Promise(r => setTimeout(r, 1500));
        const retry = await supabase.auth.getSession();
        if (retry.error || !retry.data.session) {
          window.location.href = "/connexion?error=oauth";
          return;
        }
        await handleSession(retry.data.session);
        return;
      }

      await handleSession(session);
    }

    async function handleSession(session: any) {
      const user = session.user;

      // Detect first login: created_at and last_sign_in_at within 30 seconds
      const created = new Date(user.created_at).getTime();
      const lastSignIn = new Date(user.last_sign_in_at).getTime();
      const isNewUser = Math.abs(lastSignIn - created) < 30_000;

      if (isNewUser) {
        // Fire webhook for new Google signups
        const meta = user.user_metadata || {};
        const signupSource = detectBrandFromHost(window.location.hostname) === "gmc"
          ? "gerermonchantier"
          : "verifiermondevis";
        // Meta Pixel — conversion "inscription" pour les comptes créés via Google OAuth.
        // Sans ça, les inscriptions Google n'étaient PAS comptées comme conversion : le pixel
        // n'existait que dans le flux email (Register.tsx). no-op si cookies refusés.
        trackPixel('CompleteRegistration', { content_name: signupSource });
        try {
          await fetch("/api/webhook-registration", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              email: user.email,
              phone: "",
              first_name: meta.full_name?.split(" ")[0] || meta.name || "",
              last_name: meta.full_name?.split(" ").slice(1).join(" ") || "",
              accept_commercial: false,
              signup_source: signupSource,
            }),
          });
        } catch {
          // Non-blocking
        }
        // Laisser au pixel (requête GET) le temps de partir avant la redirection
        // performPostLoginRedirect (hard navigation) — même précaution anti-race que Register.tsx.
        await new Promise(r => setTimeout(r, 400));
      }

      // Set session marker for useSessionGuard
      sessionStorage.setItem("vmd_session_active", "1");

      // Redirect: check sessionStorage first (saved before code exchange), then URL params
      const savedRedirect = sessionStorage.getItem("vmd_oauth_redirect");
      sessionStorage.removeItem("vmd_oauth_redirect");
      const params = new URLSearchParams(window.location.search);
      const redirect = savedRedirect || params.get("next") || params.get("redirect");

      // Délègue le calcul du redirect au helper partagé : il gère le SSO
      // handoff cross-domaine si l'user est sur le mauvais brand par rapport
      // à son accès produit (allowlist GMC).
      await performPostLoginRedirect({
        currentBrand: detectBrandFromHost(window.location.hostname),
        userEmail: user.email ?? "",
        accessToken: session.access_token,
        explicitRedirect: redirect,
      });
    }

    handleCallback();
  </script>
</BaseLayout>
