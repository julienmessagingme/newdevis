---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/gmc-landing/Header.astro';
import Hero from '@/components/gmc-landing/Hero.astro';
import HowItWorks from '@/components/gmc-landing/HowItWorks.astro';
import Features from '@/components/gmc-landing/Features.astro';
import PiloteSection from '@/components/gmc-landing/PiloteSection.astro';
import Pricing from '@/components/gmc-landing/Pricing.astro';
import FinalCTA from '@/components/gmc-landing/FinalCTA.astro';
import Footer from '@/components/gmc-landing/Footer.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'GérerMonChantier',
  description:
    'Le copilote IA des chantiers — planning, messagerie WhatsApp, devis, trésorerie, rappels. Vous arbitrez, le Pilote exécute.',
  url: 'https://gerermonchantier.fr',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  inLanguage: 'fr-FR',
  offers: [
    {
      '@type': 'Offer',
      price: '12',
      priceCurrency: 'EUR',
      name: 'Essentiel · mensuel',
    },
    {
      '@type': 'Offer',
      price: '120',
      priceCurrency: 'EUR',
      name: 'Essentiel · annuel',
    },
    {
      '@type': 'Offer',
      price: '25',
      priceCurrency: 'EUR',
      name: 'Multi-chantiers · mensuel',
    },
    {
      '@type': 'Offer',
      price: '210',
      priceCurrency: 'EUR',
      name: 'Multi-chantiers · annuel',
    },
  ],
  // sameAs (2026-06-09) — comptes sociaux officiels GMC. Aide Google à
  // associer le domaine aux comptes pour le Knowledge Panel + boost E-E-A-T.
  // Le compte Facebook est mutualisé VMD+GMC (cf. CLAUDE.md "Tracking / Pixels").
  sameAs: [
    'https://www.instagram.com/gerermonchantier.fr/',
    'https://www.facebook.com/profile.php?id=61590412092738',
    'https://www.tiktok.com/@gerermonchantier',
  ],
};
---

<BaseLayout
  title="GérerMonChantier — le copilote IA des chantiers"
  description="Planifier les lots, répondre aux artisans sur WhatsApp, classer les devis, suivre la trésorerie, déclencher les rappels — GMC orchestre tout. Vous arbitrez, le Pilote exécute."
  canonical="https://gerermonchantier.fr/"
  ogImage="https://gerermonchantier.fr/images/gmc/hero-illustration.png"
  siteName="GérerMonChantier"
  jsonLd={jsonLd}
>
  <div class="min-h-screen flex flex-col bg-gradient-to-b from-white via-[#F5F7FA] to-white">
    <Header />
    <main class="flex-1">
      <Hero />
      {/* Bandes de fond alternées + filets pour démarquer visuellement les sections */}
      <div class="bg-[#EEF3FC] border-y border-[#1B3FA1]/12"><HowItWorks /></div>
      <Features />
      <div class="bg-[#F5F7FB] border-y border-gray-200"><PiloteSection /></div>
      <Pricing />

      <!-- Maillage interne SEO vers les landing pages GMC -->
      <section class="py-14 px-6 bg-white border-t border-gray-100">
        <div class="max-w-[1100px] mx-auto">
          <div class="text-center max-w-2xl mx-auto mb-10">
            <h2 class="font-bold text-[#0E1730] text-3xl sm:text-4xl leading-tight tracking-tight">GérerMonChantier, par usage.</h2>
            <p class="mt-4 text-gray-600 text-base">Choisissez l'angle qui vous correspond.</p>
          </div>

          <!-- Sous-thème 1 : Vue d'ensemble -->
          <div class="mb-8">
            <p class="text-[11px] font-bold uppercase tracking-[.15em] text-[#F58A06] mb-3">Vue d'ensemble</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
              {[
                { href: "/logiciel-suivi-chantier",      title: "Logiciel de suivi chantier",      desc: "Pilotez vos travaux sans stress.",           icon: "🏗️" },
                { href: "/application-suivi-travaux",    title: "Application de suivi travaux",     desc: "Centralisez devis, budget, planning.",       icon: "📱" },
                { href: "/application-gestion-chantier", title: "Application de gestion chantier", desc: "Tout votre projet dans une appli.",          icon: "🗂️" },
              ].map(link => (
                <a href={link.href} class="block p-4 rounded-xl bg-[#F8F9FC] border border-gray-100 hover:border-[#1B3FA1]/30 hover:bg-white hover:shadow-md transition-all">
                  <div class="text-xl mb-1.5" aria-hidden="true">{link.icon}</div>
                  <p class="font-bold text-[#0E1730] text-sm mb-1">{link.title}</p>
                  <p class="text-xs text-gray-600 leading-relaxed">{link.desc}</p>
                </a>
              ))}
            </div>
          </div>

          <!-- Sous-thème 2 : Modules clés -->
          <div class="mb-8">
            <p class="text-[11px] font-bold uppercase tracking-[.15em] text-[#F58A06] mb-3">Modules clés</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
              {[
                { href: "/planning-chantier",            title: "Planning chantier",        desc: "Dates et dépendances.",       icon: "📅" },
                { href: "/suivi-budget-travaux",         title: "Suivi budget travaux",     desc: "Pilotez chaque euro.",         icon: "💸" },
                { href: "/gestion-artisans-travaux",     title: "Gestion artisans",         desc: "Fiabilité + coordination.",     icon: "👷" },
                { href: "/gestion-documents-chantier",   title: "Documents chantier",       desc: "Classement automatique.",       icon: "📂" },
              ].map(link => (
                <a href={link.href} class="block p-4 rounded-xl bg-[#F8F9FC] border border-gray-100 hover:border-[#1B3FA1]/30 hover:bg-white hover:shadow-md transition-all">
                  <div class="text-xl mb-1.5" aria-hidden="true">{link.icon}</div>
                  <p class="font-bold text-[#0E1730] text-sm mb-1">{link.title}</p>
                  <p class="text-xs text-gray-600 leading-relaxed">{link.desc}</p>
                </a>
              ))}
            </div>
          </div>

          <!-- Sous-thème 3 : Problèmes fréquents -->
          <div>
            <p class="text-[11px] font-bold uppercase tracking-[.15em] text-[#F58A06] mb-3">Problèmes fréquents</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
              {[
                { href: "/retard-chantier",              title: "Retard chantier",          desc: "Causes + comment réagir.",      icon: "⏰" },
                { href: "/surcout-travaux",              title: "Surcoût travaux",          desc: "Causes + protection.",          icon: "💰" },
                { href: "/budget-renovation",            title: "Budget rénovation",        desc: "Estimer AVANT signer.",         icon: "📊" },
                { href: "/coordination-artisans",        title: "Coordination artisans",    desc: "Aligner les corps de métier.",  icon: "🤝" },
              ].map(link => (
                <a href={link.href} class="block p-4 rounded-xl bg-[#F8F9FC] border border-gray-100 hover:border-[#1B3FA1]/30 hover:bg-white hover:shadow-md transition-all">
                  <div class="text-xl mb-1.5" aria-hidden="true">{link.icon}</div>
                  <p class="font-bold text-[#0E1730] text-sm mb-1">{link.title}</p>
                  <p class="text-xs text-gray-600 leading-relaxed">{link.desc}</p>
                </a>
              ))}
            </div>
          </div>
        </div>
      </section>

      <FinalCTA />
    </main>
    <Footer />
  </div>
</BaseLayout>
