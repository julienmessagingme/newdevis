---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HubPageApp from '@/components/app/HubPageApp';
import { breadcrumbSchema } from '@/lib/seo/schemaOrg';

const url = 'https://www.verifiermondevis.fr/etudes-vmd';
const title = "Études VMD : statistiques réelles sur les devis travaux";
const description = "Études basées sur les centaines de devis analysés par VerifierMonDevis. Erreurs fréquentes, postes surfacturés, prix variables, erreurs de TVA, oublis classiques.";

const breadcrumbs = breadcrumbSchema([
  { name: 'Accueil', url: 'https://www.verifiermondevis.fr/' },
  { name: 'Études VMD', url },
]);

// Liste les études disponibles depuis src/data/etudes-vmd
const fs = await import('node:fs');
const path = await import('node:path');
const dir = path.resolve('./src/data/etudes-vmd');
const files = fs.existsSync(dir)
  ? fs.readdirSync(dir).filter((f: string) => f.endsWith('.json') && !f.startsWith('_'))
  : [];
const studies = files.map((f: string) => JSON.parse(fs.readFileSync(path.join(dir, f), 'utf-8')));

const props = {
  breadcrumb: [{ name: 'Études VMD', href: '/etudes-vmd' }],
  title,
  intro: description,
  children: studies.map((s: any) => ({
    href: `/etudes-vmd/${s.slug}`,
    title: s.title,
    excerpt: s.description,
    topics: ['verifier', 'prix'],
    type: 'study',
  })),
  footerHtml: `
    <h2>Pourquoi ces études sont uniques</h2>
    <p>Toutes nos études sont calculées sur des <strong>devis réels</strong> analysés par notre IA et validés par notre expert humain. Pas de cherry-picking, pas de manipulation : c'est ce que nos outils mesurent vraiment.</p>
    <p>Les données sont régénérées mensuellement avec les nouveaux devis. Plus le temps passe, plus elles sont précises.</p>
    <p>Le code de génération est ouvert et auditable : <code>scripts/seo/generate-etudes-vmd.ts</code>.</p>
  `,
  showGmcGateway: true,
};

export const prerender = false;
---

<BaseLayout title={title + ' | VerifierMonDevis.fr'} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbs)} />
  <HubPageApp {...props} client:only="react" />
</BaseLayout>
