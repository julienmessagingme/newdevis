---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AstroHeader from '@/components/astro/Header.astro';
import AstroFooter from '@/components/astro/Footer.astro';

const prixParType = [
  { type: "Rénovation complète maison", unite: "m²", min: 800, moy: 1200, max: 1800, note: "Hors extension" },
  { type: "Rénovation légère (rafraîchissement)", unite: "m²", min: 150, moy: 300, max: 500, note: "Peinture, revêtements" },
  { type: "Cuisine équipée (pose + plomberie)", unite: "forfait", min: 5000, moy: 12000, max: 30000, note: "Hors électroménager" },
  { type: "Salle de bain complète", unite: "forfait", min: 4000, moy: 8000, max: 20000, note: "Petite SDB 4–6 m²" },
  { type: "Toiture (réfection complète)", unite: "m²", min: 80, moy: 130, max: 200, note: "Tuiles terre cuite" },
  { type: "Isolation intérieure (ITI)", unite: "m²", min: 40, moy: 65, max: 120, note: "Doublage placo + isolant" },
  { type: "Isolation extérieure (ITE)", unite: "m²", min: 90, moy: 140, max: 220, note: "Bardage ou enduit" },
  { type: "Carrelage pose + fourniture", unite: "m²", min: 50, moy: 75, max: 130, note: "Grès cérame standard" },
  { type: "Peinture murs et plafonds", unite: "m²", min: 15, moy: 22, max: 35, note: "2 couches + sous-couche" },
  { type: "Parquet bois (pose + fourniture)", unite: "m²", min: 45, moy: 70, max: 130, note: "Contrecollé standard" },
  { type: "Fenêtres double vitrage PVC", unite: "unité", min: 400, moy: 700, max: 1200, note: "Pose incluse" },
  { type: "Electricité (mise aux normes)", unite: "m²", min: 60, moy: 110, max: 180, note: "Logement de 80 m²" },
  { type: "Plomberie (remplacement complet)", unite: "m²", min: 40, moy: 80, max: 140, note: "Logement de 80 m²" },
  { type: "Extension maison (structure)", unite: "m²", min: 1200, moy: 1800, max: 3000, note: "Hors finitions" },
];

const faqs = [
  {
    question: "Quel est le budget moyen pour rénover une maison de 100 m² ?",
    answer: "Pour une rénovation légère (peinture, revêtements, quelques équipements), comptez entre 15 000 et 30 000 €. Pour une rénovation complète (structure, isolation, électricité, plomberie), le budget monte entre 80 000 et 150 000 €. Pour une rénovation haut de gamme, prévoyez 150 000 à 200 000 € et plus."
  },
  {
    question: "Comment réduire le coût de ses travaux de rénovation ?",
    answer: "Plusieurs leviers existent : comparer au moins 3 devis artisans (économie moyenne de 15 à 25 %), bénéficier des aides MaPrimeRénov' pour les travaux d'isolation et de chauffage, choisir des matériaux standards plutôt que haut de gamme, et grouper les chantiers pour amortir les frais de déplacement des artisans."
  },
  {
    question: "Quelles aides financières pour les travaux en 2026 ?",
    answer: "Les principales aides disponibles en 2026 : MaPrimeRénov' (jusqu'à 70 % des travaux d'isolation et chauffage), les CEE (Certificats d'Économies d'Énergie) versés par les fournisseurs d'énergie, l'éco-PTZ (prêt à 0 % jusqu'à 50 000 €), la TVA réduite à 10 % (et 5,5 % pour certains travaux d'efficacité énergétique) et les aides locales de votre commune ou région."
  },
  {
    question: "Le prix d'un artisan varie-t-il selon la région ?",
    answer: "Oui, les tarifs peuvent varier de 20 à 40 % selon la zone géographique. L'Île-de-France, la Côte d'Azur et les grandes métropoles affichent les tarifs les plus élevés. Les zones rurales et certaines régions comme le Grand Est ou la Normandie proposent généralement des tarifs plus bas. Notre outil intègre un coefficient géographique pour ajuster les comparaisons."
  },
  {
    question: "Comment éviter les mauvaises surprises sur le budget travaux ?",
    answer: "Prévoyez systématiquement une réserve de 10 à 15 % du budget initial pour les imprévus (découverte de problèmes cachés lors de la dépose, surcoûts matériaux, modifications de plan). Exigez un devis détaillé poste par poste, et ne payez les étapes que lorsqu'elles sont réalisées et validées."
  },
  {
    question: "Vaut-il mieux faire les travaux soi-même pour économiser ?",
    answer: "Pour des travaux simples (peinture, petite plomberie, pose de revêtements), le DIY peut faire économiser 30 à 50 % sur la main-d'œuvre. En revanche, pour l'électricité, la plomberie complexe ou la charpente, faites appel à un professionnel : une malfaçon peut coûter bien plus cher à réparer et peut annuler vos garanties et assurances."
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": f.answer
    }
  }))
};
---

<BaseLayout
  title="Prix travaux maison : guide complet des coûts en 2026"
  description="Quel budget pour vos travaux maison en 2026 ? Tarifs au m² par type de travaux (cuisine, SDB, toiture, isolation), conseils pour réduire la facture et comparateur de devis."
  canonical="https://www.verifiermondevis.fr/prix-travaux-maison"
  ogType="article"
  jsonLd={jsonLd}
  breadcrumbs={[
    { name: "Accueil", url: "https://www.verifiermondevis.fr/" },
    { name: "Prix travaux maison", url: "https://www.verifiermondevis.fr/prix-travaux-maison" }
  ]}
>
  <div class="min-h-screen flex flex-col">
    <AstroHeader />
    <main class="flex-1">

      <!-- ── Hero ─────────────────────────────────────────────────────────── -->
      <section class="bg-gradient-to-b from-slate-900 to-slate-800 py-14 sm:py-20 px-4">
        <div class="container max-w-3xl mx-auto text-center">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-amber-300 mb-4">Tarifs mis à jour 2026</p>
          <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-white leading-tight mb-5">
            Prix travaux maison :<br class="hidden sm:block" /> le guide complet des coûts
          </h1>
          <p class="text-base sm:text-lg text-slate-300 leading-relaxed mb-8 max-w-2xl mx-auto">
            Cuisine, salle de bain, toiture, isolation, électricité...
            Découvrez les prix au m² par type de travaux, les aides disponibles en 2026
            et les leviers pour réduire votre budget de rénovation.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a href="/nouvelle-analyse"
               class="inline-flex items-center justify-center gap-2 bg-amber-500 hover:bg-amber-400 text-white font-semibold px-6 py-3 rounded-xl transition-colors text-sm">
              🔍 Comparer avec mon devis
            </a>
            <a href="#tableau-prix"
               class="inline-flex items-center justify-center gap-2 border border-slate-500 text-slate-200 hover:bg-slate-700 px-6 py-3 rounded-xl transition-colors text-sm">
              📊 Voir les prix
            </a>
          </div>
        </div>
      </section>

      <!-- ── Contenu principal ────────────────────────────────────────────── -->
      <article class="py-12 sm:py-16 px-4">
        <div class="container max-w-3xl mx-auto">

          <!-- Intro -->
          <section class="mb-12">
            <p class="text-slate-600 leading-relaxed mb-4 text-base sm:text-lg">
              Prévoir un budget travaux sans référence, c'est naviguer à l'aveugle.
              Un artisan peut vous facturer 80 €/m² pour poser du carrelage alors que le prix du marché
              est à 50 €/m² — soit 30 % de surcoût sur l'ensemble du chantier.
              À l'inverse, un prix anormalement bas peut cacher une malfaçon future.
            </p>
            <p class="text-slate-600 leading-relaxed mb-4">
              Ce guide rassemble les <strong>prix moyens constatés en 2026</strong> pour tous les
              grands types de travaux de rénovation et de construction, issus de l'analyse de
              milliers de devis réels sur VerifierMonDevis.fr. Ces fourchettes vous permettent de
              savoir immédiatement si votre devis est dans la norme — avant même de
              <a href="/verifier-devis-travaux" class="text-indigo-600 font-medium hover:underline">vérifier un devis travaux</a> en détail.
            </p>

            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mt-6">
              {[
                { icone: "📊", titre: "Prix au m²", desc: "Par type de travaux" },
                { icone: "💡", titre: "Aides 2026", desc: "MaPrimeRénov', CEE, TVA" },
                { icone: "✂️", titre: "Économies", desc: "Conseils pour réduire la facture" },
              ].map(c => (
                <div class="text-center p-4 rounded-xl bg-white border border-slate-100 shadow-sm">
                  <span class="text-2xl mb-2 block">{c.icone}</span>
                  <p class="font-semibold text-slate-900 text-sm">{c.titre}</p>
                  <p class="text-xs text-slate-500 mt-0.5">{c.desc}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- Tableau des prix -->
          <section id="tableau-prix" class="mb-12">
            <h2 class="text-2xl font-bold text-slate-900 mb-4">Prix des travaux par type : tableau comparatif 2026</h2>
            <p class="text-slate-600 mb-6 leading-relaxed">
              Ces fourchettes sont issues de l'analyse de devis réels en France métropolitaine.
              Les prix incluent la main-d'œuvre et les matériaux standards, hors déplacements exceptionnels.
              <strong>La zone géographique peut faire varier ces tarifs de ±20 %.</strong>
            </p>

            <div class="overflow-x-auto rounded-xl border border-slate-200 shadow-sm">
              <table class="w-full text-sm border-collapse">
                <thead>
                  <tr class="bg-slate-900 text-white">
                    <th class="text-left px-4 py-3 font-semibold">Type de travaux</th>
                    <th class="text-center px-3 py-3 font-semibold whitespace-nowrap">Unité</th>
                    <th class="text-right px-3 py-3 font-semibold text-emerald-300">Min</th>
                    <th class="text-right px-3 py-3 font-semibold text-amber-300">Moyen</th>
                    <th class="text-right px-3 py-3 font-semibold text-red-300">Max</th>
                    <th class="text-left px-3 py-3 font-semibold text-slate-300 hidden sm:table-cell">Note</th>
                  </tr>
                </thead>
                <tbody>
                  {prixParType.map((row, i) => (
                    <tr class={`border-t border-slate-100 ${i % 2 === 0 ? 'bg-white' : 'bg-slate-50'} hover:bg-indigo-50/40 transition-colors`}>
                      <td class="px-4 py-3 font-medium text-slate-800">{row.type}</td>
                      <td class="px-3 py-3 text-center text-slate-500 text-xs">{row.unite}</td>
                      <td class="px-3 py-3 text-right font-semibold text-emerald-700">{row.min.toLocaleString('fr-FR')} €</td>
                      <td class="px-3 py-3 text-right font-bold text-slate-900">{row.moy.toLocaleString('fr-FR')} €</td>
                      <td class="px-3 py-3 text-right font-semibold text-red-600">{row.max.toLocaleString('fr-FR')} €</td>
                      <td class="px-3 py-3 text-slate-400 text-xs hidden sm:table-cell">{row.note}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
            <p class="text-xs text-slate-400 mt-2">* Prix indicatifs TTC en France métropolitaine, incluant main-d'œuvre et matériaux. Mis à jour en 2026.</p>
          </section>

          <!-- CTA intermédiaire -->
          <div class="my-12 rounded-2xl border border-indigo-100 bg-indigo-50 p-6 sm:p-8">
            <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
              <div class="flex-1">
                <p class="font-bold text-slate-900 mb-1">Votre devis est-il dans ces fourchettes ?</p>
                <p class="text-sm text-slate-600 leading-relaxed">
                  Importez votre devis PDF et notre outil le compare automatiquement avec ces prix du marché,
                  poste par poste — en 2 minutes.
                </p>
              </div>
              <a href="/nouvelle-analyse"
                 class="flex-shrink-0 inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold px-5 py-2.5 rounded-xl transition-colors text-sm whitespace-nowrap">
                🔍 Analyser mon devis
              </a>
            </div>
          </div>

          <!-- Prix par pièce -->
          <section class="mb-12">
            <h2 class="text-2xl font-bold text-slate-900 mb-6">Budget par pièce : ce qu'il faut prévoir</h2>

            <div class="space-y-5">

              <div class="rounded-xl border border-slate-100 bg-white shadow-sm overflow-hidden">
                <div class="flex items-center gap-3 px-5 py-4 bg-amber-50 border-b border-amber-100">
                  <span class="text-xl">🍳</span>
                  <h3 class="font-bold text-slate-900">Rénovation cuisine</h3>
                </div>
                <div class="px-5 py-4">
                  <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-3">
                    {[
                      { label: "Petite cuisine (6–8 m²)", prix: "5 000 – 12 000 €" },
                      { label: "Cuisine moyenne (10–12 m²)", prix: "12 000 – 25 000 €" },
                      { label: "Grande cuisine ouverte", prix: "25 000 – 50 000 €" },
                    ].map(c => (
                      <div class="text-center p-3 rounded-lg bg-slate-50 border border-slate-100">
                        <p class="text-xs text-slate-500 mb-1">{c.label}</p>
                        <p class="font-bold text-slate-900 text-sm">{c.prix}</p>
                      </div>
                    ))}
                  </div>
                  <p class="text-sm text-slate-600 leading-relaxed">
                    Le budget cuisine intègre : dépose de l'ancienne cuisine, plomberie, électricité dédiée,
                    meubles et électroménager, revêtements sol et mur, et pose. Les meubles représentent en moyenne
                    40 à 50 % du budget total.
                  </p>
                </div>
              </div>

              <div class="rounded-xl border border-slate-100 bg-white shadow-sm overflow-hidden">
                <div class="flex items-center gap-3 px-5 py-4 bg-blue-50 border-b border-blue-100">
                  <span class="text-xl">🚿</span>
                  <h3 class="font-bold text-slate-900">Rénovation salle de bain</h3>
                </div>
                <div class="px-5 py-4">
                  <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-3">
                    {[
                      { label: "SDB économique (4–5 m²)", prix: "4 000 – 7 000 €" },
                      { label: "SDB standard (5–8 m²)", prix: "7 000 – 15 000 €" },
                      { label: "SDB premium + douche italienne", prix: "15 000 – 30 000 €" },
                    ].map(c => (
                      <div class="text-center p-3 rounded-lg bg-slate-50 border border-slate-100">
                        <p class="text-xs text-slate-500 mb-1">{c.label}</p>
                        <p class="font-bold text-slate-900 text-sm">{c.prix}</p>
                      </div>
                    ))}
                  </div>
                  <p class="text-sm text-slate-600 leading-relaxed">
                    La salle de bain est l'une des pièces les plus onéreuses à rénover en raison de la
                    plomberie et de l'étanchéité. Le carrelage représente environ 20 à 30 % du budget,
                    la plomberie et la robinetterie 30 à 40 %.
                  </p>
                </div>
              </div>

              <div class="rounded-xl border border-slate-100 bg-white shadow-sm overflow-hidden">
                <div class="flex items-center gap-3 px-5 py-4 bg-slate-100 border-b border-slate-200">
                  <span class="text-xl">🏠</span>
                  <h3 class="font-bold text-slate-900">Toiture et charpente</h3>
                </div>
                <div class="px-5 py-4">
                  <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-3">
                    {[
                      { label: "Réfection partielle", prix: "3 000 – 8 000 €" },
                      { label: "Réfection complète (100 m²)", prix: "10 000 – 20 000 €" },
                      { label: "Toiture + isolation (Sarking)", prix: "18 000 – 35 000 €" },
                    ].map(c => (
                      <div class="text-center p-3 rounded-lg bg-slate-50 border border-slate-100">
                        <p class="text-xs text-slate-500 mb-1">{c.label}</p>
                        <p class="font-bold text-slate-900 text-sm">{c.prix}</p>
                      </div>
                    ))}
                  </div>
                  <p class="text-sm text-slate-600 leading-relaxed">
                    La toiture est un investissement prioritaire : une fuite non traitée peut entraîner
                    des dégâts sur la charpente et l'isolation, multipliant le coût par 3 ou 4.
                    Pour les travaux d'isolation toiture, vous pouvez bénéficier de MaPrimeRénov'.
                  </p>
                </div>
              </div>

            </div>
          </section>

          <!-- Aides financières -->
          <section class="mb-12">
            <h2 class="text-2xl font-bold text-slate-900 mb-6">Aides et subventions travaux en 2026</h2>
            <p class="text-slate-600 mb-6 leading-relaxed">
              De nombreuses aides permettent de réduire significativement votre budget travaux,
              notamment pour les travaux d'économie d'énergie. Voici les principales :
            </p>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {[
                {
                  nom: "MaPrimeRénov'",
                  montant: "Jusqu'à 70 % des travaux",
                  desc: "Pour l'isolation, le chauffage, la ventilation. Calculée selon vos revenus et le gain énergétique.",
                  couleur: "emerald",
                },
                {
                  nom: "CEE (Certificats d'Économies d'Énergie)",
                  montant: "Variable selon artisan",
                  desc: "Primes versées par les fournisseurs d'énergie pour les travaux d'efficacité énergétique. Cumulable avec MaPrimeRénov'.",
                  couleur: "blue",
                },
                {
                  nom: "Éco-PTZ",
                  montant: "Jusqu'à 50 000 €",
                  desc: "Prêt à taux zéro pour financer des travaux de rénovation énergétique, remboursable sur 20 ans sans intérêt.",
                  couleur: "indigo",
                },
                {
                  nom: "TVA réduite à 5,5 % ou 10 %",
                  montant: "Sur le coût total des travaux",
                  desc: "Applicable pour les travaux de rénovation dans les résidences principales de plus de 2 ans. Vérifiez l'éligibilité avec votre artisan.",
                  couleur: "amber",
                },
              ].map(a => (
                <div class={`rounded-xl border p-5 bg-${a.couleur}-50 border-${a.couleur}-100`}>
                  <p class={`font-bold text-${a.couleur}-800 mb-1`}>{a.nom}</p>
                  <p class={`text-sm font-semibold text-${a.couleur}-600 mb-2`}>{a.montant}</p>
                  <p class="text-sm text-slate-600 leading-relaxed">{a.desc}</p>
                </div>
              ))}
            </div>

            <div class="mt-5 rounded-xl border border-amber-100 bg-amber-50 p-4">
              <p class="text-sm text-amber-800">
                <strong>💡 Conseil :</strong> Certaines aides nécessitent que les travaux soient réalisés par un artisan
                <strong>RGE (Reconnu Garant de l'Environnement)</strong>. Savoir
                <a href="/choisir-artisan-travaux" class="underline font-semibold">comment choisir un artisan fiable</a> certifié RGE
                est indispensable avant de signer — notre outil vérifie cette certification automatiquement.
              </p>
            </div>
          </section>

          <!-- Conseils pour réduire la facture -->
          <section class="mb-12">
            <h2 class="text-2xl font-bold text-slate-900 mb-6">5 leviers pour réduire votre budget travaux</h2>

            <div class="space-y-4">
              {[
                {
                  icone: "🤝",
                  titre: "Comparez au moins 3 devis",
                  texte: "La mise en concurrence d'artisans vous permet d'économiser en moyenne 15 à 25 % sur le coût total. Ne choisissez pas forcément le moins cher : évaluez le rapport qualité/prix global et la fiabilité de l'entreprise."
                },
                {
                  icone: "📅",
                  titre: "Planifiez hors saison",
                  texte: "Les artisans du bâtiment sont moins sollicités entre novembre et mars. Profitez-en pour négocier des tarifs plus avantageux, et bénéficiez d'une meilleure disponibilité — vos travaux démarreront plus vite."
                },
                {
                  icone: "📦",
                  titre: "Fournissez vos matériaux",
                  texte: "Pour certains travaux (carrelage, peinture, parquet), acheter vous-même les matériaux en grande surface peut faire économiser 10 à 20 % sur le poste fournitures. Assurez-vous néanmoins que l'artisan accepte ce mode de fonctionnement."
                },
                {
                  icone: "🏗️",
                  titre: "Groupez les chantiers",
                  texte: "Si vous prévoyez plusieurs postes de travaux (salle de bain + carrelage salon + peinture), un seul artisan multi-corps ou un coordonnateur de travaux peut vous faire économiser sur les frais de déplacement et simplifier la gestion."
                },
                {
                  icone: "💰",
                  titre: "Mobilisez les aides avant de commencer",
                  texte: "Certaines aides (MaPrimeRénov', CEE) doivent être demandées AVANT le début des travaux. Renseignez-vous auprès de votre ANAH départementale ou sur le site france-renov.gouv.fr avant de signer le moindre devis."
                },
              ].map(c => (
                <div class="flex items-start gap-4 p-5 rounded-xl border border-slate-100 bg-white shadow-sm">
                  <span class="flex-shrink-0 text-2xl">{c.icone}</span>
                  <div>
                    <h3 class="font-semibold text-slate-900 mb-1">{c.titre}</h3>
                    <p class="text-sm text-slate-600 leading-relaxed">{c.texte}</p>
                  </div>
                </div>
              ))}
            </div>
          </section>

          <!-- Erreurs fréquentes budget -->
          <section class="mb-12">
            <h2 class="text-2xl font-bold text-slate-900 mb-6">Les 4 erreurs qui font exploser le budget travaux</h2>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {[
                {
                  titre: "Sous-estimer les imprévus",
                  texte: "Une fois les murs ouverts, les surprises sont fréquentes : humidité cachée, câblage non conforme, structure fragilisée... Prévoyez toujours 10 à 15 % de réserve sur votre budget initial.",
                },
                {
                  titre: "Négliger les finitions",
                  texte: "Les finitions (plinthes, joints, peintures de reprise, nettoyage de chantier) représentent 5 à 10 % du budget total. Mal estimées, elles peuvent créer des tensions avec l'artisan ou des dépenses supplémentaires non prévues.",
                },
                {
                  titre: "Changer d'avis en cours de chantier",
                  texte: "Chaque modification une fois le chantier commencé coûte en moyenne 2 à 3 fois plus cher que si elle avait été intégrée au devis initial. Définissez précisément vos choix avant de signer.",
                },
                {
                  titre: "Confondre prix HT et TTC",
                  texte: "Pour des travaux de rénovation dans une résidence principale de plus de 2 ans, la TVA est de 10 % (parfois 5,5 %). Vérifiez que votre devis applique le bon taux — la différence peut représenter 10 % du montant total.",
                },
              ].map(e => (
                <div class="p-5 rounded-xl border-l-4 border-red-400 bg-red-50/50 border border-red-100">
                  <h3 class="font-semibold text-slate-900 mb-2">⚠️ {e.titre}</h3>
                  <p class="text-sm text-slate-600 leading-relaxed">{e.texte}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- Silo piliers -->
          <section class="mb-12">
