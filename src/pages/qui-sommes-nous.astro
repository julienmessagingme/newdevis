---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AstroHeader from '@/components/astro/Header.astro';
import AstroFooter from '@/components/astro/Footer.astro';
---

<BaseLayout
  title="Qui sommes-nous ? | VerifierMonDevis.fr"
  description="Julien Dumas (assurance) et Johan Bridey (banque) : deux experts avec 40 ans d'expérience cumulée au service des particuliers face aux devis artisans."
  canonical="https://www.verifiermondevis.fr/qui-sommes-nous"
  breadcrumbs={[
    { name: "Accueil", url: "https://www.verifiermondevis.fr/" },
    { name: "Qui sommes-nous", url: "https://www.verifiermondevis.fr/qui-sommes-nous" }
  ]}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "name": "Qui sommes-nous — VerifierMonDevis.fr",
    "url": "https://www.verifiermondevis.fr/qui-sommes-nous",
    "mainEntity": {
      "@type": "Organization",
      "name": "VerifierMonDevis.fr",
      "url": "https://www.verifiermondevis.fr",
      "email": "contact@verifiermondevis.fr",
      "description": "Service d'analyse de devis d'artisans fondé par Julien Dumas et Johan Bridey",
      "logo": "https://www.verifiermondevis.fr/images/logo.webp",
      "foundingDate": "2026",
      "founder": [
        {
          "@type": "Person",
          "name": "Julien Dumas",
          "jobTitle": "Co-fondateur, Assurance & Opérations",
          "description": "20 ans en assurance (Groupama Gan Vie, PRO BTP), directeur d'opérations sur +300 M€ d'encours"
        },
        {
          "@type": "Person",
          "name": "Johan Bridey",
          "jobTitle": "Co-fondateur, Risque & Analyse Financière",
          "description": "20 ans en banque (CIC, HSBC, CCF), manager d'un pôle crédit immobilier Sud-Ouest"
        }
      ]
    }
  }}
>
  <div class="min-h-screen flex flex-col">
    <AstroHeader />
    <main class="flex-1">

      <!-- ============================================================ -->
      <!-- HERO — bleu marine foncé                                      -->
      <!-- ============================================================ -->
      <section class="py-20 px-4 text-center qsn-dark">
        <div class="max-w-4xl mx-auto">
          <span class="inline-block border border-amber-400/50 text-amber-400 text-xs uppercase tracking-[0.22em] px-5 py-1.5 mb-10">
            Qui sommes-nous
          </span>
          <h1 class="text-4xl sm:text-5xl font-bold text-white leading-tight mb-6">
            Deux experts au service<br />
            d'<span class="text-amber-400">une seule cause</span>&nbsp;: la vôtre.
          </h1>
          <p class="text-slate-300 max-w-2xl mx-auto text-lg leading-relaxed">
            Nous avons passé des années à analyser des risques, des contrats et des
            dossiers financiers complexes. Aujourd'hui, nous mettons cette expertise à votre
            disposition&nbsp;— avant que vous ne signiez.
          </p>
          <div class="w-12 h-0.5 bg-amber-400 mx-auto mt-12"></div>
        </div>
      </section>

      <!-- ============================================================ -->
      <!-- POURQUOI CE SITE — fond blanc, texte centré                  -->
      <!-- ============================================================ -->
      <section class="py-16 px-4 bg-white">
        <div class="max-w-3xl mx-auto text-center">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-amber-500 mb-5">
            Pourquoi ce site
          </p>
          <h2 class="text-3xl font-bold text-slate-900 leading-tight mb-10">
            Nous avons vu trop de gens signer<br />
            sans vraiment comprendre ce qu'ils signaient.
          </h2>

          <div class="text-slate-600 space-y-5 text-base leading-relaxed">
            <p>
              Entre nos deux parcours, nous avons accompagné des <strong class="text-slate-800">centaines de clients</strong> —
              particuliers, artisans, professionnels — dans des moments délicats. Des sinistres mal couverts.
              Des travaux facturés bien au-delà du raisonnable. Des devis signés dans l'urgence, sans que personne
              n'ait pris le temps de les lire vraiment. Et des situations qui auraient pu être évitées avec un
              regard averti au bon moment.
            </p>
            <p>
              Ce constat, nous l'avons fait indépendamment, chacun de notre côté. Julien, depuis les plateaux de
              gestion sinistres et les directions d'opérations en assurance. Johan, depuis les bureaux bancaires
              où des clients arrivaient déjà dans l'ennui, après avoir engagé des travaux sans vérifier ni les
              garanties ni la cohérence des prix.
            </p>
            <p>
              <strong class="text-slate-800">VerifierMonDevis.fr est né de cette frustration partagée</strong>&nbsp;: et si on
              pouvait intervenir <em>avant</em>&nbsp;? Pas pour réparer les dégâts, mais pour les éviter. Pas en jouant
              les experts inaccessibles, mais en rendant lisible ce qui est trop souvent opaque.
            </p>
          </div>

          <blockquote class="mt-10 border-l-4 border-amber-400 pl-6 text-left max-w-xl mx-auto">
            <p class="text-slate-600 italic text-base leading-relaxed">
              «&nbsp;Un devis, ça se lit comme un contrat. Et un contrat mal compris, ça coûte
              toujours plus cher que prévu.&nbsp;»
            </p>
          </blockquote>
        </div>
      </section>

      <!-- ============================================================ -->
      <!-- FONDATEURS — header marine foncé + cartes blanches           -->
      <!-- ============================================================ -->
      <section class="qsn-dark">
        <div class="max-w-5xl mx-auto">

          <!-- Photos & noms -->
          <div class="grid grid-cols-1 sm:grid-cols-2">

            <!-- Julien Dumas -->
            <div class="py-12 px-8 text-center sm:border-r border-b sm:border-b-0 border-slate-700">
              <div class="qsn-photo-wrap mx-auto mb-5">
                <img src="/images/julien-dumas.webp" alt="Julien Dumas" class="qsn-photo" width="140" height="140" loading="lazy" />
              </div>
              <h3 class="text-white font-bold text-xl mb-2">Julien Dumas</h3>
              <p class="text-amber-400 text-xs font-semibold uppercase tracking-wider leading-relaxed">
                Co-fondateur · Assurance &amp;<br />Opérations
              </p>
            </div>

            <!-- Johan Bridey -->
            <div class="py-12 px-8 text-center">
              <div class="qsn-photo-wrap mx-auto mb-5">
                <img src="/images/johan-bridey.webp" alt="Johan Bridey" class="qsn-photo" width="140" height="140" loading="lazy" />
              </div>
              <h3 class="text-white font-bold text-xl mb-2">Johan Bridey</h3>
              <p class="text-amber-400 text-xs font-semibold uppercase tracking-wider leading-relaxed">
                Co-fondateur · Risque &amp; Analyse<br />Financière
              </p>
            </div>
          </div>

          <!-- Bios + bullets — fond blanc -->
          <div class="grid grid-cols-1 sm:grid-cols-2 bg-white">

            <!-- Julien bio -->
            <div class="p-8 sm:border-r border-b sm:border-b-0 border-slate-100">
              <div class="text-slate-600 space-y-4 text-sm leading-relaxed mb-6">
                <p>
                  Vingt ans au cœur des grandes organisations assurantielles — Groupama Gan Vie, PRO BTP,
                  co-fondateur de Messaging Me. Julien a piloté des équipes, géré des centaines de millions
                  d'euros d'encours, industrialisé des gammes de produits et négocié des contrats grands comptes.
                  Il connaît les pratiques du marché de l'intérieur&nbsp;: ce que valent les prestations, comment se
                  structurent les marges, où se cachent les imprécisions qui coûtent cher.
                </p>
                <p>
                  Mais au-delà du professionnel, il y a aussi le particulier. Investisseur dans l'immobilier
                  locatif, Julien a été confronté de plain-pied à la réalité des travaux de rénovation&nbsp;: trouver
                  des artisans fiables, décrypter des devis parfois opaques, arbitrer entre plusieurs offres sans
                  repère objectif. <strong class="text-slate-800">Cette double expérience — expert du marché ET client
                  néophyte — lui donne une lecture unique</strong>&nbsp;: il sait exactement où regarder, parce
                  qu'il a lui-même cherché à y voir clair.
                </p>
              </div>
              <hr class="border-slate-200 mb-5" />
              <ul class="space-y-3.5">
                <li class="flex items-start gap-3 text-sm text-slate-700">
                  <span class="qsn-check flex-shrink-0 mt-0.5">✓</span>
                  <span><strong>20 ans en assurance</strong> — santé, prévoyance, IARD, emprunteur, marchés BTP</span>
                </li>
                <li class="flex items-start gap-3 text-sm text-slate-700">
                  <span class="qsn-check flex-shrink-0 mt-0.5">✓</span>
                  <span><strong>Directeur d'opérations</strong> sur +300&nbsp;M€ d'encours clients (PRO BTP, Groupama)</span>
                </li>
                <li class="flex items-start gap-3 text-sm text-slate-700">
                  <span class="qsn-check flex-shrink-0 mt-0.5">✓</span>
                  <span><strong>Investisseur immobilier</strong> — confronté aux mêmes difficultés que vous face aux devis d'artisans</span>
                </li>
              </ul>
            </div>

            <!-- Johan bio -->
            <div class="p-8">
              <div class="text-slate-600 space-y-4 text-sm leading-relaxed mb-6">
                <p>
                  Vingt ans dans la banque forgent un œil. Chez CIC, HSBC puis CCF, Johan a passé sa carrière
                  à analyser des dossiers complexes&nbsp;: crédits immobiliers, risques professionnels, montages
                  patrimoniaux. Manager d'un pôle de crédit immobilier sur tout le Sud-Ouest, il a pris des
                  décisions engageant parfois plusieurs millions d'euros. Dans ce métier, on apprend vite&nbsp;:
                  <strong class="text-slate-800">un document mal lu, c'est un risque accepté sans le savoir.</strong>
                </p>
                <p>
                  Mais Johan n'est pas qu'un analyste de bureau. Il a mené de bout en bout, sans l'aide d'un
                  professionnel, la rénovation complète de sa résidence principale — création de surface
                  incluse. Coordination des corps de métier, lecture des devis, gestion des imprévus&nbsp;:
                  <strong class="text-slate-800">il a vécu de l'intérieur ce que vivent ses utilisateurs.</strong>
                  Cette expérience terrain lui a appris ce qu'aucun manuel bancaire n'enseigne&nbsp;: la complexité
                  réelle d'un projet de travaux pour un particulier non initié.
                </p>
              </div>
              <hr class="border-slate-200 mb-5" />
              <ul class="space-y-3.5">
                <li class="flex items-start gap-3 text-sm text-slate-700">
                  <span class="qsn-check flex-shrink-0 mt-0.5">✓</span>
                  <span><strong>20 ans en banque</strong> — analyse crédit, risque, expertise immobilière (CIC, HSBC, CCF)</span>
                </li>
                <li class="flex items-start gap-3 text-sm text-slate-700">
                  <span class="qsn-check flex-shrink-0 mt-0.5">✓</span>
                  <span><strong>Manager d'un pôle crédit immobilier</strong> Sud-Ouest — décisions jusqu'à 1,5&nbsp;M€</span>
                </li>
                <li class="flex items-start gap-3 text-sm text-slate-700">
                  <span class="qsn-check flex-shrink-0 mt-0.5">✓</span>
                  <span><strong>Maître d'ouvrage aguerri</strong> — rénovation complète menée seul, de A à Z</span>
                </li>
              </ul>
            </div>

          </div>
        </div>
      </section>

      <!-- ============================================================ -->
      <!-- CE QUE NOUS PROMETTONS — marine foncé, 4 cards              -->
      <!-- ============================================================ -->
      <section class="py-20 px-4 text-center qsn-dark">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-3xl sm:text-4xl font-bold text-white mb-5 leading-tight">
            Ce que nous vous promettons&nbsp;:<br />
            <span class="text-amber-400">clarté, indépendance, utilité.</span>
          </h2>
          <p class="text-slate-300 max-w-2xl mx-auto mb-14 leading-relaxed">
            Nous n'avons aucun lien commercial avec les artisans. Nous ne touchons aucune
            commission. Nous ne vendons pas vos données. Notre seul intérêt, c'est que vous
            soyez bien informé avant de signer.
          </p>

          <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
            <div class="border border-slate-600 rounded p-6 text-center">
              <div class="text-3xl mb-4">🔍</div>
              <p class="text-amber-400 text-[11px] font-bold uppercase tracking-wider leading-relaxed">
                Analyse<br />indépendante
              </p>
            </div>
            <div class="border border-slate-600 rounded p-6 text-center">
              <div class="text-3xl mb-4">🛡️</div>
              <p class="text-amber-400 text-[11px] font-bold uppercase tracking-wider leading-relaxed">
                Expertise métier<br />réelle
              </p>
            </div>
            <div class="border border-slate-600 rounded p-6 text-center">
              <div class="text-3xl mb-4">⚖️</div>
              <p class="text-amber-400 text-[11px] font-bold uppercase tracking-wider leading-relaxed">
                Sans conflit<br />d'intérêt
              </p>
            </div>
            <div class="border border-slate-600 rounded p-6 text-center">
              <div class="text-3xl mb-4">📋</div>
              <p class="text-amber-400 text-[11px] font-bold uppercase tracking-wider leading-relaxed">
                Rapport clair &amp;<br />actionnable
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- ============================================================ -->
      <!-- CTA — fond crème / beige clair                               -->
      <!-- ============================================================ -->
      <section class="py-20 px-4 text-center qsn-cream">
        <div class="max-w-2xl mx-auto">
          <p class="text-slate-600 text-lg mb-2">
            Vous avez un devis entre les mains et un doute dans la tête&nbsp;?
          </p>
          <p class="text-slate-900 font-bold text-xl mb-10">
            C'est exactement pour ça que nous sommes là.
          </p>
          <a
            href="/nouvelle-analyse"
            class="qsn-btn inline-flex items-center justify-center px-10 py-3.5 text-sm font-bold uppercase tracking-[0.15em] rounded text-white"
          >
            Soumettre mon devis
          </a>
        </div>
      </section>

      <!-- ============================================================ -->
      <!-- NOUS CONTACTER + FORMULAIRE — ajouté à la fin               -->
      <!-- ============================================================ -->
      <section class="py-14 border-t border-border bg-background">
        <div class="container max-w-2xl px-4">
          <h2 class="text-2xl font-bold text-foreground mb-2">Nous contacter</h2>
          <p class="text-muted-foreground mb-8">Une question, une suggestion ou un signalement&nbsp;? Nous vous répondons sous 48h.</p>

          <form
            action="https://api.web3forms.com/submit"
            method="POST"
            id="contact-form"
            class="space-y-6"
          >
            <input type="hidden" name="access_key" value="0bdbe892-3eef-4a5e-9915-87d190d6e145" />
            <input type="checkbox" name="botcheck" class="hidden" style="display:none" />
            <input type="hidden" name="subject" value="Nouveau message depuis VerifierMonDevis.fr" />
            <input type="hidden" name="from_name" value="VerifierMonDevis.fr" />
            <input type="hidden" name="redirect" value="https://www.verifiermondevis.fr/qui-sommes-nous?success=true" />

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="qsn-name" class="block text-sm font-medium text-foreground mb-1.5">Nom *</label>
                <input
                  type="text" name="name" id="qsn-name" required
                  placeholder="Votre nom"
                  class="w-full h-10 px-3 rounded-md border border-input bg-background text-foreground text-sm placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2"
                />
              </div>
              <div>
                <label for="qsn-email" class="block text-sm font-medium text-foreground mb-1.5">Email *</label>
                <input
                  type="email" name="email" id="qsn-email" required
                  placeholder="votre@email.fr"
                  class="w-full h-10 px-3 rounded-md border border-input bg-background text-foreground text-sm placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2"
                />
              </div>
            </div>

            <div>
              <label for="qsn-category" class="block text-sm font-medium text-foreground mb-1.5">Objet</label>
              <select
                name="category" id="qsn-category"
                class="w-full h-10 px-3 rounded-md border border-input bg-background text-foreground text-sm focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2"
              >
                <option value="question">Question sur le service</option>
                <option value="suggestion">Suggestion d'amélioration</option>
                <option value="bug">Signaler un problème technique</option>
                <option value="rectification">Demande de rectification (artisan)</option>
                <option value="rgpd">Exercer mes droits (RGPD)</option>
                <option value="autre">Autre</option>
              </select>
            </div>

            <div>
              <label for="qsn-message" class="block text-sm font-medium text-foreground mb-1.5">Message *</label>
              <textarea
                name="message" id="qsn-message" required rows="5"
                placeholder="Décrivez votre demande..."
                class="w-full px-3 py-2 rounded-md border border-input bg-background text-foreground text-sm placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2 resize-y"
              ></textarea>
            </div>

            <button
              type="submit"
              class="inline-flex items-center justify-center rounded-md bg-primary text-primary-foreground hover:bg-primary/90 h-10 px-6 text-sm font-medium w-full sm:w-auto"
            >
              Envoyer le message
            </button>
          </form>

          <!-- Message de succès -->
          <div id="success-message" style="display:none" class="mt-8 bg-score-green-bg border border-score-green/20 rounded-xl p-6 text-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-score-green mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <p class="text-foreground font-medium mb-1">Message envoyé !</p>
            <p class="text-sm text-muted-foreground">Merci pour votre message. Nous vous répondrons dans les meilleurs délais.</p>
          </div>

          <!-- Autres moyens de contact -->
          <div class="mt-10 grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-card border border-border rounded-xl p-5">
              <div class="flex items-center gap-3 mb-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                </svg>
                <p class="text-sm font-medium text-foreground">Par email</p>
              </div>
              <a href="mailto:contact@verifiermondevis.fr" class="text-sm text-primary hover:underline">
                contact@verifiermondevis.fr
              </a>
            </div>
            <div class="bg-card border border-border rounded-xl p-5">
              <div class="flex items-center gap-3 mb-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z" />
                </svg>
                <p class="text-sm font-medium text-foreground">Questions fréquentes</p>
              </div>
              <a href="/faq" class="text-sm text-primary hover:underline">Consultez notre FAQ</a>
            </div>
          </div>

        </div>
      </section>

    </main>
    <AstroFooter />
  </div>
</BaseLayout>

<style>
  /* Fond bleu marine foncé du PDF */
  .qsn-dark {
    background-color: #0d1e3a;
  }

  /* Fond crème/beige du CTA PDF */
  .qsn-cream {
    background-color: #f5ede0;
  }

  /* Conteneur photo — seul anneau doré visible */
  .qsn-photo-wrap {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    border: 3px solid #c9a84c;
    overflow: hidden;
    /* Léger halo doré externe */
    box-shadow: 0 0 0 4px rgba(201, 168, 76, 0.18);
  }

  /* Photo : cadrage portrait */
  .qsn-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 15%;
    display: block;
  }

  /* Checkmark doré dans les bullets */
  .qsn-check {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background-color: #c9a84c;
    color: white;
    font-size: 10px;
    font-weight: bold;
    flex-shrink: 0;
  }

  /* Bouton CTA doré */
  .qsn-btn {
    background-color: #c9a84c;
    transition: background-color 0.2s;
  }
  .qsn-btn:hover {
    background-color: #b8963e;
  }
</style>

<script>
  if (new URLSearchParams(window.location.search).get('success') === 'true') {
    var form = document.getElementById('contact-form');
    var msg = document.getElementById('success-message');
    if (form) (form as HTMLElement).style.display = 'none';
    if (msg) (msg as HTMLElement).style.display = 'block';
    history.replaceState({}, '', '/qui-sommes-nous');
  }
</script>
