---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HubPageApp from '@/components/app/HubPageApp';
import { breadcrumbSchema } from '@/lib/seo/schemaOrg';

const url = 'https://www.verifiermondevis.fr/observatoire';
const title = "Observatoire des devis travaux : nos analyses en chiffres";
const description = "L'Observatoire VerifierMonDevis : études, statistiques prix par métier et par type de chantier, calculées à partir des devis analysés par notre outil.";

const breadcrumbs = breadcrumbSchema([
  { name: 'Accueil', url: 'https://www.verifiermondevis.fr/' },
  { name: 'Observatoire', url },
]);

// Liste les études disponibles depuis src/data/observatoire
const fs = await import('node:fs');
const path = await import('node:path');
const dir = path.resolve('./src/data/observatoire');
const files = fs.existsSync(dir)
  ? fs.readdirSync(dir).filter((f: string) => f.endsWith('.json') && !f.startsWith('_'))
  : [];
const studies = files.map((f: string) => JSON.parse(fs.readFileSync(path.join(dir, f), 'utf-8')));

const props = {
  breadcrumb: [{ name: 'Observatoire', href: '/observatoire' }],
  title,
  intro: description,
  subPages: studies.map((s: any) => ({
    href: `/observatoire/${s.slug}`,
    title: s.title,
    excerpt: s.description,
    topics: ['verifier', 'prix'],
    type: 'study',
  })),
  footerHtml: `
    <h2>Comment nous construisons ces statistiques</h2>
    <p>Chaque chiffre publié ici est calculé à partir des devis analysés par VerifierMonDevis. Nous ne prétendons pas représenter le marché national : nous publions ce que nos outils mesurent réellement sur notre échantillon.</p>
    <p>Les données sont régénérées chaque mois avec les nouveaux devis. Plus notre base grandit, plus les fourchettes deviennent précises.</p>
    <p>Le code de génération est ouvert et auditable : <code>scripts/observatoire/generate-observatoire.ts</code>.</p>
  `,
  showGmcGateway: true,
};

export const prerender = false;
---

<BaseLayout title={title + ' | VerifierMonDevis.fr'} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbs)} />
  <HubPageApp {...props} client:only="react" />
</BaseLayout>
