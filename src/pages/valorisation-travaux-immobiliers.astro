              <a href="/faq" class="inline-flex items-center gap-1.5 border border-slate-300 text-slate-700 hover:bg-slate-50 px-4 py-2 rounded-lg transition-colors">
                FAQ
              </a>
              <a href="/blog" class="inline-flex items-center gap-1.5 border border-slate-300 text-slate-700 hover:bg-slate-50 px-4 py-2 rounded-lg transition-colors">
                Blog
              </a>
            </div>

            <!-- CTA 5 — bas de page -->
            <div class="rounded-xl bg-primary/5 border border-primary/20 p-6 text-center">
              <p class="font-semibold text-slate-800 mb-1">Prêt à analyser votre devis ?</p>
              <p class="text-sm text-slate-500 mb-4">Gratuit, confidentiel, résultat en 2 minutes.</p>
              <a
                href="/nouvelle-analyse"
                class="inline-flex items-center justify-center gap-2 bg-primary text-primary-foreground hover:bg-primary/90 font-semibold px-6 py-3 rounded-xl transition-colors text-sm"
              >
                Analyser mon devis et estimer la valorisation
              </a>
            </div>
          </section>

        </div>
      </article>
    </main>

    <AstroFooter />
  </div>
