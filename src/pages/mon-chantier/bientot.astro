---
import BaseLayout from '@/layouts/BaseLayout.astro';

export const prerender = false;
---

<BaseLayout
  title="Mon Chantier — Bientôt disponible | VerifierMonDevis.fr"
  description="La fonctionnalité Mon Chantier arrive bientôt sur VerifierMonDevis.fr"
  noindex={true}
>
  <div class="min-h-screen bg-background flex items-center justify-center px-4">
    <div class="text-center max-w-lg">
      <div class="text-6xl mb-6">🏗️</div>
      <h1 class="text-3xl sm:text-4xl font-bold text-foreground mb-4">
        Bientôt disponible
      </h1>
      <p class="text-lg text-muted-foreground mb-3">
        <strong class="text-foreground">Mon Chantier</strong> est en cours de développement.
      </p>
      <p class="text-muted-foreground mb-8">
        Gérez vos devis, votre budget, vos contacts artisans et suivez l'avancement de vos travaux — le tout depuis un seul espace.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/tableau-de-bord" class="inline-flex items-center justify-center rounded-lg bg-primary text-primary-foreground px-6 py-3 text-sm font-medium hover:bg-primary/90 transition-colors">
          Retour au tableau de bord
        </a>
        <a href="/nouvelle-analyse" class="inline-flex items-center justify-center rounded-lg border border-border bg-card text-foreground px-6 py-3 text-sm font-medium hover:bg-accent transition-colors">
          Analyser un devis
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
